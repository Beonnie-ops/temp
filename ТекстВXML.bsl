////////////////////////////////////////////////////////////////////////////////
// Модуль: ТекстВXML
//
// Назначение:
//   Сборка XML из данных, представленных в текстовом (табличном) формате,
//   для дальнейшей удобной обработки.
//
//   Модуль содержит два подхода:
//     1. Универсальный конвертер: любой разделённый текст (CSV/TSV) -> XML,
//        где первая строка задаёт имена колонок, остальные строки — данные.
//     2. Специализированный сбор XML накладной/ЭСЧФ формата "issuance"
//        (см. пример 101454161-2026-00001383282.xml в этом каталоге).
//
//   Для формирования XML используется объект ЗаписьXML, поэтому:
//     - спецсимволы (< > & " ') экранируются автоматически;
//     - гарантируется корректная кодировка UTF-8 и валидность документа.
//
// Совместимость: 1С:Предприятие 8.3 (управляемое/обычное приложение),
//   код серверный/внешней обработки, не зависит от конфигурации и БСП.
////////////////////////////////////////////////////////////////////////////////

#Область УниверсальныйКонвертер

// Собирает XML из разделённого текста (CSV/TSV).
//
// Первая непустая строка текста трактуется как заголовок с именами колонок.
// Каждая последующая строка становится элементом <Строка>, а значения —
// вложенными элементами с именами колонок (недопустимые для XML символы в
// именах заменяются на "_").
//
// Параметры:
//   ТекстДанных   - Строка - исходные данные (многострочный текст).
//   Разделитель   - Строка - разделитель колонок (по умолчанию Таб).
//   ИмяКорня      - Строка - имя корневого элемента (по умолчанию "Данные").
//   ИмяСтроки     - Строка - имя элемента строки (по умолчанию "Строка").
//
// Возвращаемое значение:
//   Строка - готовый XML-документ.
//
Функция ТабличныйТекстВXML(Знач ТекстДанных, Знач Разделитель = Неопределено,
	Знач ИмяКорня = "Данные", Знач ИмяСтроки = "Строка") Экспорт

	Если Разделитель = Неопределено Тогда
		Разделитель = Символы.Таб;
	КонецЕсли;

	Строки = РазбитьНаСтроки(ТекстДанных);
	Если Строки.Количество() = 0 Тогда
		ВызватьИсключение "Не переданы данные для сборки XML.";
	КонецЕсли;

	Колонки = РазложитьСтроку(Строки[0], Разделитель);
	Для Индекс = 0 По Колонки.Количество() - 1 Цикл
		Колонки[Индекс] = БезопасноеИмяЭлемента(Колонки[Индекс], "Поле" + (Индекс + 1));
	КонецЦикла;

	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку("UTF-8");
	Запись.ЗаписатьОбъявлениеXML();
	Запись.ЗаписатьНачалоЭлемента(БезопасноеИмяЭлемента(ИмяКорня, "Данные"));

	Для НомерСтроки = 1 По Строки.Количество() - 1 Цикл
		ТекущаяСтрока = Строки[НомерСтроки];
		Если СокрЛП(ТекущаяСтрока) = "" Тогда
			Продолжить;
		КонецЕсли;

		Значения = РазложитьСтроку(ТекущаяСтрока, Разделитель);
		Запись.ЗаписатьНачалоЭлемента(БезопасноеИмяЭлемента(ИмяСтроки, "Строка"));
		Запись.ЗаписатьАтрибут("н", Формат(НомерСтроки, "ЧГ=0"));

		Для Индекс = 0 По Колонки.Количество() - 1 Цикл
			Значение = ?(Индекс < Значения.Количество(), Значения[Индекс], "");
			ЗаписатьЭлементСоЗначением(Запись, Колонки[Индекс], Значение);
		КонецЦикла;

		Запись.ЗаписатьКонецЭлемента(); // Строка
	КонецЦикла;

	Запись.ЗаписатьКонецЭлемента(); // Корень
	Возврат Запись.Закрыть();

КонецФункции

#КонецОбласти

#Область НакладнаяISSUANCE

// Собирает XML накладной (формат "issuance") из текстового описания.
//
// Ожидаемый формат текста:
//   * Блок "шапки" — строки вида "Ключ = Значение" (по одной на строку).
//   * Строка-маркер "[ТОВАРЫ]" (в любом регистре) отделяет шапку от таблицы товаров.
//   * Далее табличная часть: первая строка — имена колонок, разделённых
//     табуляцией или ";", остальные строки — товары.
//
// Обязательные/поддерживаемые ключи шапки (регистр не важен):
//   sender, number, dateIssuance, dateTransaction, documentType,
//   providerUnp, providerName, providerAddress,
//   recipientUnp, recipientName, recipientAddress,
//   contractNumber, contractDate
//
// Поддерживаемые колонки товаров (регистр не важен):
//   name, code, units, count, price, vatRate
//   (cost, summaVat, costVat при отсутствии вычисляются автоматически).
//
// Итоги roster (totalCost, totalVat, totalCostVat, totalExcise)
// вычисляются автоматически по товарам.
//
// Параметры:
//   ТекстОписания - Строка - текстовое описание накладной.
//
// Возвращаемое значение:
//   Строка - готовый XML-документ формата "issuance".
//
Функция СобратьНакладнуюIssuance(Знач ТекстОписания) Экспорт

	Данные = РазобратьОписаниеНакладной(ТекстОписания);
	Шапка   = Данные.Шапка;
	Товары  = Данные.Товары;

	Итоги = Новый Структура("Стоимость, НДС, СтоимостьСНДС, Акциз", 0, 0, 0, 0);
	Для Каждого Товар Из Товары Цикл
		Итоги.Стоимость     = Итоги.Стоимость     + Товар.cost;
		Итоги.НДС           = Итоги.НДС           + Товар.summaVat;
		Итоги.СтоимостьСНДС = Итоги.СтоимостьСНДС + Товар.costVat;
		Итоги.Акциз         = Итоги.Акциз         + Товар.summaExcise;
	КонецЦикла;

	ПространствоИмён = "http://www.w3schools.com";

	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку("UTF-8");
	Запись.ЗаписатьОбъявлениеXML();

	Запись.ЗаписатьНачалоЭлемента("issuance");
	Запись.ЗаписатьАтрибут("xmlns", ПространствоИмён);
	Запись.ЗаписатьАтрибут("sender", ЗначениеШапки(Шапка, "sender"));

	// general
	Запись.ЗаписатьНачалоЭлемента("general");
	ЗаписатьЭлементСоЗначением(Запись, "number",          ЗначениеШапки(Шапка, "number"));
	ЗаписатьЭлементСоЗначением(Запись, "dateIssuance",    ЗначениеШапки(Шапка, "dateIssuance"));
	ЗаписатьЭлементСоЗначением(Запись, "dateTransaction", ЗначениеШапки(Шапка, "dateTransaction"));
	ЗаписатьЭлементСоЗначением(Запись, "documentType",    ЗначениеШапки(Шапка, "documentType", "ORIGINAL"));
	Запись.ЗаписатьКонецЭлемента(); // general

	// provider
	Запись.ЗаписатьНачалоЭлемента("provider");
	ЗаписатьЭлементСоЗначением(Запись, "providerStatus",       ЗначениеШапки(Шапка, "providerStatus", "SELLER"));
	ЗаписатьЭлементСоЗначением(Запись, "dependentPerson",      ЗначениеШапки(Шапка, "providerDependentPerson", "false"));
	ЗаписатьЭлементСоЗначением(Запись, "residentsOfOffshore",  ЗначениеШапки(Шапка, "providerResidentsOfOffshore", "false"));
	ЗаписатьЭлементСоЗначением(Запись, "specialDealGoods",     ЗначениеШапки(Шапка, "providerSpecialDealGoods", "false"));
	ЗаписатьЭлементСоЗначением(Запись, "bigCompany",           ЗначениеШапки(Шапка, "providerBigCompany", "false"));
	ЗаписатьЭлементСоЗначением(Запись, "countryCode",          ЗначениеШапки(Шапка, "providerCountryCode", "112"));
	ЗаписатьЭлементСоЗначением(Запись, "unp",                  ЗначениеШапки(Шапка, "providerUnp"));
	ЗаписатьЭлементСоЗначением(Запись, "name",                 ЗначениеШапки(Шапка, "providerName"));
	ЗаписатьЭлементСоЗначением(Запись, "address",              ЗначениеШапки(Шапка, "providerAddress"));
	Запись.ЗаписатьКонецЭлемента(); // provider

	// recipient
	Запись.ЗаписатьНачалоЭлемента("recipient");
	ЗаписатьЭлементСоЗначением(Запись, "recipientStatus",      ЗначениеШапки(Шапка, "recipientStatus", "CUSTOMER"));
	ЗаписатьЭлементСоЗначением(Запись, "dependentPerson",      ЗначениеШапки(Шапка, "recipientDependentPerson", "false"));
	ЗаписатьЭлементСоЗначением(Запись, "residentsOfOffshore",  ЗначениеШапки(Шапка, "recipientResidentsOfOffshore", "false"));
	ЗаписатьЭлементСоЗначением(Запись, "specialDealGoods",     ЗначениеШапки(Шапка, "recipientSpecialDealGoods", "false"));
	ЗаписатьЭлементСоЗначением(Запись, "bigCompany",           ЗначениеШапки(Шапка, "recipientBigCompany", "false"));
	ЗаписатьЭлементСоЗначением(Запись, "countryCode",          ЗначениеШапки(Шапка, "recipientCountryCode", "112"));
	ЗаписатьЭлементСоЗначением(Запись, "unp",                  ЗначениеШапки(Шапка, "recipientUnp"));
	ЗаписатьЭлементСоЗначением(Запись, "name",                 ЗначениеШапки(Шапка, "recipientName"));
	ЗаписатьЭлементСоЗначением(Запись, "address",              ЗначениеШапки(Шапка, "recipientAddress"));
	Запись.ЗаписатьКонецЭлемента(); // recipient

	// senderReceiver (грузоотправитель / грузополучатель)
	Запись.ЗаписатьНачалоЭлемента("senderReceiver");
	Запись.ЗаписатьНачалоЭлемента("consignors");
	Запись.ЗаписатьНачалоЭлемента("consignor");
	ЗаписатьЭлементСоЗначением(Запись, "countryCode", ЗначениеШапки(Шапка, "consignorCountryCode", ЗначениеШапки(Шапка, "providerCountryCode", "112")));
	ЗаписатьЭлементСоЗначением(Запись, "unp",         ЗначениеШапки(Шапка, "consignorUnp",         ЗначениеШапки(Шапка, "providerUnp")));
	ЗаписатьЭлементСоЗначением(Запись, "name",        ЗначениеШапки(Шапка, "consignorName",        ЗначениеШапки(Шапка, "providerName")));
	ЗаписатьЭлементСоЗначением(Запись, "address",     ЗначениеШапки(Шапка, "consignorAddress",     ЗначениеШапки(Шапка, "providerAddress")));
	Запись.ЗаписатьКонецЭлемента(); // consignor
	Запись.ЗаписатьКонецЭлемента(); // consignors

	Запись.ЗаписатьНачалоЭлемента("consignees");
	Запись.ЗаписатьНачалоЭлемента("consignee");
	ЗаписатьЭлементСоЗначением(Запись, "countryCode", ЗначениеШапки(Шапка, "consigneeCountryCode", ЗначениеШапки(Шапка, "recipientCountryCode", "112")));
	ЗаписатьЭлементСоЗначением(Запись, "unp",         ЗначениеШапки(Шапка, "consigneeUnp",         ЗначениеШапки(Шапка, "recipientUnp")));
	ЗаписатьЭлементСоЗначением(Запись, "name",        ЗначениеШапки(Шапка, "consigneeName",        ЗначениеШапки(Шапка, "recipientName")));
	ЗаписатьЭлементСоЗначением(Запись, "address",     ЗначениеШапки(Шапка, "consigneeAddress",     ""));
	Запись.ЗаписатьКонецЭлемента(); // consignee
	Запись.ЗаписатьКонецЭлемента(); // consignees
	Запись.ЗаписатьКонецЭлемента(); // senderReceiver

	// deliveryCondition (основание — договор/документ)
	Запись.ЗаписатьНачалоЭлемента("deliveryCondition");
	Запись.ЗаписатьНачалоЭлемента("contract");
	Запись.ЗаписатьНачалоЭлемента("documents");
	Запись.ЗаписатьНачалоЭлемента("document");
	Запись.ЗаписатьНачалоЭлемента("docType");
	ЗаписатьЭлементСоЗначением(Запись, "code", ЗначениеШапки(Шапка, "contractDocCode", "0"));
	Запись.ЗаписатьКонецЭлемента(); // docType
	ЗаписатьЭлементСоЗначением(Запись, "date",   ЗначениеШапки(Шапка, "contractDate"));
	ЗаписатьЭлементСоЗначением(Запись, "number", ЗначениеШапки(Шапка, "contractNumber"));
	Запись.ЗаписатьКонецЭлемента(); // document
	Запись.ЗаписатьКонецЭлемента(); // documents
	Запись.ЗаписатьКонецЭлемента(); // contract
	Запись.ЗаписатьКонецЭлемента(); // deliveryCondition

	// roster (табличная часть с итогами)
	Запись.ЗаписатьНачалоЭлемента("roster");
	Запись.ЗаписатьАтрибут("totalCostVat", ФорматЧисла(Итоги.СтоимостьСНДС));
	Запись.ЗаписатьАтрибут("totalExcise",  ФорматЧисла(Итоги.Акциз));
	Запись.ЗаписатьАтрибут("totalVat",     ФорматЧисла(Итоги.НДС));
	Запись.ЗаписатьАтрибут("totalCost",    ФорматЧисла(Итоги.Стоимость));

	НомерТовара = 0;
	Для Каждого Товар Из Товары Цикл
		НомерТовара = НомерТовара + 1;
		Запись.ЗаписатьНачалоЭлемента("rosterItem");
		ЗаписатьЭлементСоЗначением(Запись, "number",      Формат(НомерТовара, "ЧГ=0"));
		ЗаписатьЭлементСоЗначением(Запись, "name",        Товар.name);
		ЗаписатьЭлементСоЗначением(Запись, "code",        Товар.code);
		ЗаписатьЭлементСоЗначением(Запись, "units",       Товар.units);
		ЗаписатьЭлементСоЗначением(Запись, "count",       ФорматЧисла(Товар.count, 5, Ложь));
		ЗаписатьЭлементСоЗначением(Запись, "price",       ФорматЧисла(Товар.price));
		ЗаписатьЭлементСоЗначением(Запись, "cost",        ФорматЧисла(Товар.cost));
		ЗаписатьЭлементСоЗначением(Запись, "summaExcise", ФорматЧисла(Товар.summaExcise));
		Запись.ЗаписатьНачалоЭлемента("vat");
		ЗаписатьЭлементСоЗначением(Запись, "rate",     ФорматЧисла(Товар.vatRate, 4));
		ЗаписатьЭлементСоЗначением(Запись, "rateType", Товар.rateType);
		ЗаписатьЭлементСоЗначением(Запись, "summaVat", ФорматЧисла(Товар.summaVat));
		Запись.ЗаписатьКонецЭлемента(); // vat
		ЗаписатьЭлементСоЗначением(Запись, "costVat", ФорматЧисла(Товар.costVat));
		Запись.ЗаписатьКонецЭлемента(); // rosterItem
	КонецЦикла;

	Запись.ЗаписатьКонецЭлемента(); // roster
	Запись.ЗаписатьКонецЭлемента(); // issuance

	Возврат Запись.Закрыть();

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Разбирает текстовое описание накладной на шапку и таблицу товаров.
Функция РазобратьОписаниеНакладной(Знач ТекстОписания)

	Шапка = Новый Соответствие;
	Товары = Новый Массив;
	ТекущийРаздел = "ШАПКА";
	КолонкиТоваров = Неопределено;

	Строки = РазбитьНаСтроки(ТекстОписания);
	Для Каждого Строка Из Строки Цикл
		ОчищеннаяСтрока = СокрЛП(Строка);
		Если ОчищеннаяСтрока = "" Тогда
			Продолжить;
		КонецЕсли;

		Если ВРег(ОчищеннаяСтрока) = "[ТОВАРЫ]" ИЛИ ВРег(ОчищеннаяСтрока) = "[ITEMS]" Тогда
			ТекущийРаздел = "ТОВАРЫ";
			Продолжить;
		КонецЕсли;

		Если ТекущийРаздел = "ШАПКА" Тогда
			ПозицияРавно = Найти(ОчищеннаяСтрока, "=");
			Если ПозицияРавно > 0 Тогда
				Ключ = СокрЛП(Лев(ОчищеннаяСтрока, ПозицияРавно - 1));
				Значение = СокрЛП(Сред(ОчищеннаяСтрока, ПозицияРавно + 1));
				Шапка.Вставить(ВРег(Ключ), Значение);
			КонецЕсли;
		Иначе
			Разделитель = ОпределитьРазделительТаблицы(Строка);
			Если КолонкиТоваров = Неопределено Тогда
				КолонкиТоваров = РазложитьСтроку(Строка, Разделитель);
				Для Индекс = 0 По КолонкиТоваров.Количество() - 1 Цикл
					КолонкиТоваров[Индекс] = НРег(СокрЛП(КолонкиТоваров[Индекс]));
				КонецЦикла;
			Иначе
				Значения = РазложитьСтроку(Строка, Разделитель);
				Товары.Добавить(СобратьТовар(КолонкиТоваров, Значения));
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	Возврат Новый Структура("Шапка, Товары", Шапка, Товары);

КонецФункции

// Собирает структуру одного товара, вычисляя недостающие суммы.
Функция СобратьТовар(Знач Колонки, Знач Значения)

	Поля = Новый Соответствие;
	Для Индекс = 0 По Колонки.Количество() - 1 Цикл
		Значение = ?(Индекс < Значения.Количество(), СокрЛП(Значения[Индекс]), "");
		Поля.Вставить(Колонки[Индекс], Значение);
	КонецЦикла;

	Товар = Новый Структура;
	Товар.Вставить("name",        ПолеСоответствия(Поля, "name"));
	Товар.Вставить("code",        ПолеСоответствия(Поля, "code"));
	Товар.Вставить("units",       ПолеСоответствия(Поля, "units", "796"));
	Товар.Вставить("count",       ЧислоИзСтроки(ПолеСоответствия(Поля, "count", "0")));
	Товар.Вставить("price",       ЧислоИзСтроки(ПолеСоответствия(Поля, "price", "0")));
	Товар.Вставить("vatRate",     ЧислоИзСтроки(ПолеСоответствия(Поля, "vatrate", "0")));
	Товар.Вставить("rateType",    ПолеСоответствия(Поля, "ratetype", "CALCULATED"));
	Товар.Вставить("summaExcise", ЧислоИзСтроки(ПолеСоответствия(Поля, "summaexcise", "0")));

	// Стоимость без НДС: берём из данных либо вычисляем как цена * количество.
	СтрокаСтоимости = ПолеСоответствия(Поля, "cost", "");
	Если СтрокаСтоимости = "" Тогда
		Товар.Вставить("cost", Окр(Товар.price * Товар.count, 2));
	Иначе
		Товар.Вставить("cost", ЧислоИзСтроки(СтрокаСтоимости));
	КонецЕсли;

	ЕстьНДС     = (ПолеСоответствия(Поля, "summavat", "") <> "");
	ЕстьСтГросс = (ПолеСоответствия(Поля, "costvat", "") <> "");

	Если ЕстьНДС Тогда
		Товар.Вставить("summaVat", ЧислоИзСтроки(Поля.Получить("summavat")));
	ИначеЕсли ВРег(Товар.rateType) = "CALCULATED" И Товар.vatRate > 0 И Товар.vatRate < 100 Тогда
		// Расчётная ставка: НДС выделяется из стоимости (сумма — брутто).
		// Брутто = нетто / (1 - ставка/100); НДС = брутто - нетто.
		СтоимостьСНДС = Окр(Товар.cost / (1 - Товар.vatRate / 100), 2);
		Товар.Вставить("summaVat", СтоимостьСНДС - Товар.cost);
	Иначе
		// Обычная ставка: НДС начисляется сверху стоимости.
		Товар.Вставить("summaVat", Окр(Товар.cost * Товар.vatRate / 100, 2));
	КонецЕсли;

	// Стоимость с НДС.
	Если ЕстьСтГросс Тогда
		Товар.Вставить("costVat", ЧислоИзСтроки(Поля.Получить("costvat")));
	Иначе
		Товар.Вставить("costVat", Окр(Товар.cost + Товар.summaVat, 2));
	КонецЕсли;

	Возврат Товар;

КонецФункции

// Записывает элемент XML с текстовым значением (пустое значение -> пустой элемент).
Процедура ЗаписатьЭлементСоЗначением(Запись, Знач ИмяЭлемента, Знач Значение)
	Запись.ЗаписатьНачалоЭлемента(ИмяЭлемента);
	Если ЗначениеЗаполнено(Значение) Тогда
		Запись.ЗаписатьТекст(Строка(Значение));
	КонецЕсли;
	Запись.ЗаписатьКонецЭлемента();
КонецПроцедуры

// Возвращает значение ключа шапки или значение по умолчанию.
Функция ЗначениеШапки(Знач Шапка, Знач Ключ, Знач ЗначениеПоУмолчанию = "")
	Значение = Шапка.Получить(ВРег(Ключ));
	Если Значение = Неопределено ИЛИ СокрЛП(Значение) = "" Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Возврат Значение;
КонецФункции

// Возвращает значение поля соответствия или значение по умолчанию.
Функция ПолеСоответствия(Знач Соответствие, Знач Ключ, Знач ЗначениеПоУмолчанию = "")
	Значение = Соответствие.Получить(Ключ);
	Если Значение = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Возврат Значение;
КонецФункции

// Разбивает многострочный текст на массив строк (с учётом разных переводов строк).
Функция РазбитьНаСтроки(Знач Текст)
	Текст = СтрЗаменить(Текст, Символы.ВК, "");
	Возврат СтрРазделить(Текст, Символы.ПС, Истина);
КонецФункции

// Разбивает строку по разделителю на массив значений (с удалением пробелов).
Функция РазложитьСтроку(Знач Строка, Знач Разделитель)
	Результат = СтрРазделить(Строка, Разделитель, Истина);
	Для Индекс = 0 По Результат.Количество() - 1 Цикл
		Результат[Индекс] = СокрЛП(Результат[Индекс]);
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Определяет разделитель табличной части: таб, ";" или ",".
Функция ОпределитьРазделительТаблицы(Знач Строка)
	Если Найти(Строка, Символы.Таб) > 0 Тогда
		Возврат Символы.Таб;
	ИначеЕсли Найти(Строка, ";") > 0 Тогда
		Возврат ";";
	КонецЕсли;
	Возврат ",";
КонецФункции

// Преобразует строку в число, поддерживая запятую и точку как разделитель.
// Разбор выполняется вручную (независимо от региональных настроек).
Функция ЧислоИзСтроки(Знач Строка)
	Строка = СтрЗаменить(СокрЛП(Строка), " ", "");
	Строка = СтрЗаменить(Строка, ",", ".");
	Строка = СтрЗаменить(Строка, Символ(160), ""); // неразрывный пробел
	Если Строка = "" Тогда
		Возврат 0;
	КонецЕсли;

	Знак = 1;
	Если Лев(Строка, 1) = "-" Тогда
		Знак = -1;
		Строка = Сред(Строка, 2);
	ИначеЕсли Лев(Строка, 1) = "+" Тогда
		Строка = Сред(Строка, 2);
	КонецЕсли;

	Части = СтрРазделить(Строка, ".", Истина);
	ЦелаяЧасть = ?(Части.Количество() > 0, Части[0], "0");
	ДробнаяЧасть = ?(Части.Количество() > 1, Части[1], "");

	Результат = ЦелоеИзЦифр(ЦелаяЧасть);
	Если ДробнаяЧасть <> "" Тогда
		Результат = Результат + ЦелоеИзЦифр(ДробнаяЧасть) / Pow(10, СтрДлина(ДробнаяЧасть));
	КонецЕсли;

	Возврат Знак * Результат;
КонецФункции

// Собирает целое число из строки цифр (нецифровые символы игнорируются).
Функция ЦелоеИзЦифр(Знач Строка)
	Цифры = "0123456789";
	Результат = 0;
	Для Позиция = 1 По СтрДлина(Строка) Цикл
		Символ = Сред(Строка, Позиция, 1);
		Индекс = Найти(Цифры, Символ);
		Если Индекс > 0 Тогда
			Результат = Результат * 10 + (Индекс - 1);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Форматирует число для XML: точка как разделитель, без групп разрядов.
// По умолчанию убирает незначащие нули (1.20 -> 1.2, 1.00 -> 1).
// При УбратьНезначащиеНули = Ложь сохраняет фиксированное число знаков
// (например, для количества: 1 -> 1.00000).
Функция ФорматЧисла(Знач Число, Знач Точность = 2, Знач УбратьНезначащиеНули = Истина)
	Строка = Формат(Число, "ЧДЦ=" + Строка(Точность) + "; ЧРД=.; ЧГ=0");
	Если УбратьНезначащиеНули И Найти(Строка, ".") > 0 Тогда
		Пока Прав(Строка, 1) = "0" Цикл
			Строка = Лев(Строка, СтрДлина(Строка) - 1);
		КонецЦикла;
		Если Прав(Строка, 1) = "." Тогда
			Строка = Лев(Строка, СтрДлина(Строка) - 1);
		КонецЕсли;
	КонецЕсли;
	Возврат Строка;
КонецФункции

// Приводит произвольную строку к допустимому имени XML-элемента.
Функция БезопасноеИмяЭлемента(Знач ИмяИсходное, Знач ИмяПоУмолчанию = "Поле")
	ИмяИсходное = СокрЛП(ИмяИсходное);
	Если ИмяИсходное = "" Тогда
		Возврат ИмяПоУмолчанию;
	КонецЕсли;

	ДопустимыеСимволы = "АБВГДЕЁЖЗИЙКЛМНОПРСТУФХЦЧШЩЪЫЬЭЮЯабвгдеёжзийклмнопрстуфхцчшщъыьэюя"
		+ "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789_";
	Результат = "";
	Для Позиция = 1 По СтрДлина(ИмяИсходное) Цикл
		Символ = Сред(ИмяИсходное, Позиция, 1);
		Результат = Результат + ?(Найти(ДопустимыеСимволы, Символ) > 0, Символ, "_");
	КонецЦикла;

	// Имя XML не может начинаться с цифры.
	Первый = Лев(Результат, 1);
	Если Найти("0123456789", Первый) > 0 Тогда
		Результат = "_" + Результат;
	КонецЕсли;

	Возврат Результат;
КонецФункции

