////////////////////////////////////////////////////////////////////////////////
// Формирование XML-контейнера BLRDOC (версия 2.0) из ссылки на документ 1С.
//
// Контейнер BLRDOC ("Иной документ", TypeCode = OTHER) используется в белорусском
// электронном документообороте (EDI) для передачи произвольного файла (например,
// PDF) через оператора ЭДО. Структура полностью повторяет файл v8_E3C_13.xml,
// лежащий в этом репозитории:
//
// <BLRDOC version="2.0">
//   <DocumentAttributes>
//     <DocumentID>001-4819004750004-01-13006260002</DocumentID>
//     <CreationDateTime>20260630104922</CreationDateTime>     (ггггММддЧЧммсс)
//     <FunctionCode>9</FunctionCode>
//     <eDocumentRoute>1</eDocumentRoute>
//     <eDocumentNumber>ЛБР00008092</eDocumentNumber>
//     <eDocumentDate>20260630</eDocumentDate>                  (ггггММдд)
//     <eDocumentType>
//       <TypeName>Иной документ</TypeName>
//       <TypeCode>OTHER</TypeCode>
//     </eDocumentType>
//     <Sender><LegalPerson>
//       <GLN/><Name/><Address/><VATRegistrationNumber/>
//     </LegalPerson></Sender>
//     <Receiver><LegalPerson>
//       <GLN/><Name/><Address/><VATRegistrationNumber/>
//     </LegalPerson></Receiver>
//   </DocumentAttributes>
//   <Document>
//     <eDocumentFile>BASE64...</eDocumentFile>
//     <eDocumentFileType>pdf</eDocumentFileType>
//     <eDocumentFileName>v8_E3C_12</eDocumentFileName>
//   </Document>
// </BLRDOC>
//
// КАК ИСПОЛЬЗОВАТЬ (минимальный пример):
//
//   ДвоичныеДанные = Новый ДвоичныеДанные("C:\Документы\v8_E3C_12.pdf");
//   ТекстXML = СформироватьСтрокуBLRDOC(СсылкаНаДокумент, ДвоичныеДанные, "v8_E3C_12");
//   // либо сразу записать в файл:
//   СформироватьФайлBLRDOC(СсылкаНаДокумент, ДвоичныеДанные, "v8_E3C_12",
//       "C:\Выгрузка\v8_E3C_13.xml");
//
// Места, которые нужно адаптировать под конкретную конфигурацию, помечены
// комментарием "// АДАПТИРОВАТЬ".
////////////////////////////////////////////////////////////////////////////////

// Формирует текст XML-контейнера BLRDOC и возвращает его строкой.
//
// Параметры:
//   ДокументСсылка       - ДокументСсылка - документ-источник (из него берутся
//                          организация-отправитель и контрагент-получатель,
//                          а также номер/дата для атрибутов контейнера).
//   ДвоичныеДанныеФайла  - ДвоичныеДанные  - содержимое присоединяемого файла (PDF и т.п.).
//   ИмяФайла             - Строка          - имя файла без расширения (eDocumentFileName).
//   ТипФайла             - Строка          - расширение/тип файла (eDocumentFileType), по умолчанию "pdf".
//
// Возвращаемое значение:
//   Строка - готовый XML в кодировке UTF-8.
//
Функция СформироватьСтрокуBLRDOC(ДокументСсылка, ДвоичныеДанныеФайла, ИмяФайла, ТипФайла = "pdf") Экспорт

	// 1. Собираем реквизиты отправителя и получателя из документа.
	Отправитель = ДанныеУчастникаПоОрганизации(ДокументСсылка.Организация);  // АДАПТИРОВАТЬ
	Получатель  = ДанныеУчастникаПоКонтрагенту(ДокументСсылка.Контрагент);   // АДАПТИРОВАТЬ

	// 2. Готовим атрибуты контейнера.
	МоментСоздания  = ТекущаяДата();
	ДатаДокумента   = ?(ЗначениеЗаполнено(ДокументСсылка.Дата), ДокументСсылка.Дата, МоментСоздания);
	НомерДокумента  = СокрЛП(ДокументСсылка.Номер);
	ИдентификаторДок = СформироватьDocumentID(Отправитель.GLN);

	// 3. Кодируем файл в Base64 одной строкой (без переводов строк).
	Base64Файла = Base64СтрокаБезПереносов(ДвоичныеДанныеФайла);

	// 4. Пишем XML.
	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку("UTF-8");
	Запись.ЗаписатьОбъявлениеXML();

	Запись.ЗаписатьНачалоЭлемента("BLRDOC");
	Запись.ЗаписатьАтрибут("version", "2.0");

		Запись.ЗаписатьНачалоЭлемента("DocumentAttributes");

			ЗаписатьЭлементСоЗначением(Запись, "DocumentID",      ИдентификаторДок);
			ЗаписатьЭлементСоЗначением(Запись, "CreationDateTime", Формат(МоментСоздания, "ДФ=ггггММддЧЧммсс"));
			ЗаписатьЭлементСоЗначением(Запись, "FunctionCode",     "9");
			ЗаписатьЭлементСоЗначением(Запись, "eDocumentRoute",   "1");
			ЗаписатьЭлементСоЗначением(Запись, "eDocumentNumber",  НомерДокумента);
			ЗаписатьЭлементСоЗначением(Запись, "eDocumentDate",    Формат(ДатаДокумента, "ДФ=ггггММдд"));

			Запись.ЗаписатьНачалоЭлемента("eDocumentType");
				ЗаписатьЭлементСоЗначением(Запись, "TypeName", "Иной документ");
				ЗаписатьЭлементСоЗначением(Запись, "TypeCode", "OTHER");
			Запись.ЗаписатьКонецЭлемента(); // eDocumentType

			ЗаписатьУчастника(Запись, "Sender",   Отправитель);
			ЗаписатьУчастника(Запись, "Receiver", Получатель);

		Запись.ЗаписатьКонецЭлемента(); // DocumentAttributes

		Запись.ЗаписатьНачалоЭлемента("Document");
			ЗаписатьЭлементСоЗначением(Запись, "eDocumentFile",     Base64Файла);
			ЗаписатьЭлементСоЗначением(Запись, "eDocumentFileType", ТипФайла);
			ЗаписатьЭлементСоЗначением(Запись, "eDocumentFileName", ИмяФайла);
		Запись.ЗаписатьКонецЭлемента(); // Document

	Запись.ЗаписатьКонецЭлемента(); // BLRDOC

	Возврат Запись.Закрыть();

КонецФункции

// Формирует контейнер BLRDOC и записывает его в файл на диске.
//
// Параметры:
//   ДокументСсылка      - ДокументСсылка - см. СформироватьСтрокуBLRDOC.
//   ДвоичныеДанныеФайла - ДвоичныеДанные  - содержимое присоединяемого файла.
//   ИмяФайла            - Строка          - имя файла без расширения.
//   ПолноеИмяФайлаXML   - Строка          - путь, по которому сохранить XML.
//   ТипФайла            - Строка          - тип файла, по умолчанию "pdf".
//
Процедура СформироватьФайлBLRDOC(ДокументСсылка, ДвоичныеДанныеФайла, ИмяФайла, ПолноеИмяФайлаXML, ТипФайла = "pdf") Экспорт

	ТекстXML = СформироватьСтрокуBLRDOC(ДокументСсылка, ДвоичныеДанныеФайла, ИмяФайла, ТипФайла);

	ТекстовыйДокумент = Новый ТекстовыйДокумент;
	ТекстовыйДокумент.УстановитьТекст(ТекстXML);
	ТекстовыйДокумент.Записать(ПолноеИмяФайлаXML, КодировкаТекста.UTF8);

КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ
////////////////////////////////////////////////////////////////////////////////

// Записывает простой элемент <Имя>Значение</Имя>.
Процедура ЗаписатьЭлементСоЗначением(Запись, ИмяЭлемента, Значение)
	Запись.ЗаписатьНачалоЭлемента(ИмяЭлемента);
	Запись.ЗаписатьТекст(СокрЛП(Строка(Значение)));
	Запись.ЗаписатьКонецЭлемента();
КонецПроцедуры

// Записывает блок участника (Sender/Receiver) с вложенным LegalPerson.
Процедура ЗаписатьУчастника(Запись, ИмяБлока, ДанныеУчастника)
	Запись.ЗаписатьНачалоЭлемента(ИмяБлока);
		Запись.ЗаписатьНачалоЭлемента("LegalPerson");
			ЗаписатьЭлементСоЗначением(Запись, "GLN",                  ДанныеУчастника.GLN);
			ЗаписатьЭлементСоЗначением(Запись, "Name",                 ДанныеУчастника.Наименование);
			ЗаписатьЭлементСоЗначением(Запись, "Address",              ДанныеУчастника.Адрес);
			ЗаписатьЭлементСоЗначением(Запись, "VATRegistrationNumber", ДанныеУчастника.УНП);
		Запись.ЗаписатьКонецЭлемента(); // LegalPerson
	Запись.ЗаписатьКонецЭлемента(); // ИмяБлока
КонецПроцедуры

// Возвращает структуру данных участника по организации.
// АДАПТИРОВАТЬ: имена реквизитов (GLN, УНП, адрес) зависят от конфигурации.
Функция ДанныеУчастникаПоОрганизации(Организация)
	Данные = НоваяСтруктураУчастника();
	Данные.GLN          = СокрЛП(Организация.GLN);                 // АДАПТИРОВАТЬ
	Данные.Наименование = СокрЛП(Организация.НаименованиеПолное);  // АДАПТИРОВАТЬ
	Данные.Адрес        = ПочтовыйАдресУчастника(Организация);     // АДАПТИРОВАТЬ
	Данные.УНП          = СокрЛП(Организация.УНП);                 // АДАПТИРОВАТЬ (в РФ — ИНН/КПП)
	Возврат Данные;
КонецФункции

// Возвращает структуру данных участника по контрагенту.
// АДАПТИРОВАТЬ: имена реквизитов зависят от конфигурации.
Функция ДанныеУчастникаПоКонтрагенту(Контрагент)
	Данные = НоваяСтруктураУчастника();
	Данные.GLN          = СокрЛП(Контрагент.GLN);                  // АДАПТИРОВАТЬ
	Данные.Наименование = СокрЛП(Контрагент.НаименованиеПолное);   // АДАПТИРОВАТЬ
	Данные.Адрес        = ПочтовыйАдресУчастника(Контрагент);      // АДАПТИРОВАТЬ
	Данные.УНП          = СокрЛП(Контрагент.УНП);                  // АДАПТИРОВАТЬ
	Возврат Данные;
КонецФункции

// Заготовка структуры участника обмена.
Функция НоваяСтруктураУчастника()
	Данные = Новый Структура;
	Данные.Вставить("GLN",          "");
	Данные.Вставить("Наименование", "");
	Данные.Вставить("Адрес",        "");
	Данные.Вставить("УНП",          "");
	Возврат Данные;
КонецФункции

// Возвращает почтовый адрес участника строкой.
// АДАПТИРОВАТЬ: способ получения адреса зависит от конфигурации
// (контактная информация, реквизит ЮрАдрес и т.п.).
Функция ПочтовыйАдресУчастника(ЭлементСправочника)
	Попытка
		Возврат СокрЛП(ЭлементСправочника.ЮридическийАдрес);
	Исключение
		Возврат "";
	КонецПопытки;
КонецФункции

// Формирует значение DocumentID вида "001-<GLN отправителя>-01-<уникальный номер>".
// АДАПТИРОВАТЬ: схема нумерации может задаваться оператором ЭДО.
Функция СформироватьDocumentID(GLNОтправителя)
	// Уникальная часть на основе текущего момента; при необходимости заменить
	// на собственный счётчик/идентификатор сообщения оператора ЭДО.
	УникальныйНомер = Формат(ТекущаяУниверсальнаяДатаВМиллисекундах(), "ЧГ=0");
	Возврат "001-" + СокрЛП(GLNОтправителя) + "-01-" + УникальныйНомер;
КонецФункции

// Кодирует двоичные данные в Base64 без переводов строк (как в v8_E3C_13.xml).
Функция Base64СтрокаБезПереносов(ДвоичныеДанные)
	Результат = Base64Строка(ДвоичныеДанные);
	Результат = СтрЗаменить(Результат, Символы.ВК, "");
	Результат = СтрЗаменить(Результат, Символы.ПС, "");
	Возврат Результат;
КонецФункции
