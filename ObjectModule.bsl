Процедура КоманднаяПанель1ОтчетПоПолученномуТопливу(Кнопка)
	
	Если Заправки.Количество() > 0 Тогда
		
		ТЗДляОтчета = Новый ТаблицаЗначений;	
		ТЗДляОтчета = Заправки.Выгрузить(,"НомерЭК,Водитель,Получено,Сумма");
		ТЗДляОтчета.Свернуть("Водитель,НомерЭК,","Получено,Сумма");
		ТЗДляОтчета.Сортировать("Водитель");
		
		ТабДок = Новый ТабличныйДокумент;
		
		Макет = ПолучитьМакет("СводныйОтчет");
		
		ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
		ОбластьСтрока    = Макет.ПолучитьОбласть("Строка");
		ОбластьИтого     = Макет.ПолучитьОбласть("Итого");
		
		ТабДок.Вывести(ОбластьЗаголовок);
		
		Для каждого Строка Из ТЗДляОтчета Цикл
		
			ОбластьСтрока.Параметры.Заполнить(Строка);		
		    ТабДок.Вывести(ОбластьСтрока);
			
		КонецЦикла; 
		
		ОбластьИтого.Параметры.ИтогоПолучено = ТЗДляОтчета.Итог("Получено");
		ОбластьИтого.Параметры.ИтогоСумма    = ТЗДляОтчета.Итог("Сумма"); 
		
		ТабДок.Вывести(ОбластьИтого);
		
		ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
		ТабДок.АвтоМасштаб = Истина;
		
		ТабДок.Показать("Сводный отчет по заправкам");
				
	Иначе
		
		Сообщить("Сначала нужно загрузить файл с информацией о заправках");	
		
	КонецЕсли; 
	
КонецПроцедуры

