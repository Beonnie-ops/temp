				ТекущаяСтрока.РасстояниеГород = 200;
				ТекущаяСтрока.РасстояниеТрасса = ПоТрассе;
				ТекущаяСтрока.РасходТрасса = ТекущаяСтрока.РасстояниеТрасса * Объект.РасходТопливаТрасса / 100;
				ТекущаяСтрока.МаршрутКуда = "Трасса";
				ТекущаяСтрока.МаршрутОткуда = "Трасса";
			КонецЕсли;
		КонецЕсли;
		
		Если  Объект.ДопКолКМ = 0 тогда
			ДопрРасходНачало1 = 	Макс(рандом(10),Рандом(12));
		Иначе
			рр=1;
			пока ДопрРасходНачало=ДопрРасходНачало1 Цикл 
				Если РР%11 =0 тогда	
					прервать;
				КонецЕсли;	
			рр=рр+1;	
			ДопрРасходНачало1 = 	Макс(Мин(Объект.ДопКолКМ+рандом(2),Рандом(Объект.ДопКолКМ+1)),Рандом(Объект.ДопКолКМ))
			КонецЦикла;
		КонецЕсли;	
		 Состояние(ДопрРасходНачало);
		Если ДопрРасходНачало=ДопрРасходНачало1 тогда
			ДопрРасходНачало =ДопрРасходНачало1+ рандом(1) ;
		Иначе 
			ДопрРасходНачало =ДопрРасходНачало1;  
		КонецЕсли;	
		
		//ТекущаяСтрока.НачальныйСпидометр = КонечныйСпидометр + ?(ТекущаяСтрока.РасходГород+ТекущаяСтрока.РасстояниеТрасса<>0, ДопрРасходНачало,0) + ТекущаяСтрока.КорректировкаНачальногоСпидометра;
		
		ТекущаяСтрока.НачальныйСпидометр = КонечныйСпидометр + ТекущаяСтрока.КорректировкаНачальногоСпидометра + Объект.ДопКолКМ;
		
		ТекущаяСтрока.КонечныйСпидометр = ТекущаяСтрока.НачальныйСпидометр + ТекущаяСтрока.РасстояниеГород +ТекущаяСтрока.РасстояниеТрасса;	
		ТекущаяСтрока.Расстояние  = ТекущаяСтрока.РасстояниеГород +ТекущаяСтрока.РасстояниеТрасса;
		//ТекущаяСтрока.РасходГород = Объект.РасходТоплива * (ТекущаяСтрока.Расстояние-ТекущаяСтрока.РасстояниеТрасса) / 100;
		//ТекущаяСтрока.РасходТрасса = Объект.РасходТопливаТрасса * ТекущаяСтрока.РасстояниеТрасса / 100; //20220305. Павел
