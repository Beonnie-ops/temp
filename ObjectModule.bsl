Функция СледЗаправка(ТЗ,К)
	КК =К;
	Если ((ТЗ.Количество()-1>КК)и(КК>=1)) Тогда
		КК=КК+1;
		Пока КК<=ТЗ.Количество()-1 Цикл
			СтрТЗ =	ТЗ[КК];//ТЗ.ПолучитьСтрокуПоНомеру(К);
			Если СтрТЗ.Получено<>0 Тогда
				Возврат СтрТЗ.Получено;
			КонецЕсли;
			КК=КК+1;			
		КонецЦикла;      
	КонецЕсли;    
	возврат 0;
КонецФункции                

// Процедуры и функции для постобработики таблицы значений, чтобы равномерно распределить топливо

//Денис 2026 04
Функция РаспределитьТопливо(ТаблицаДней, ЕмкостьБака) Экспорт
	
	Результат = ТаблицаДней.Скопировать();
	Результат.Сортировать("Дата");
	Результат.Колонки.Добавить("РасходТрасса", Новый ОписаниеТипов("Число"));
	
	РаспределятьНаДней = 0;
	ПоследнийРабочийДень = Неопределено;
	
	
	Для Каждого Стр Из Результат Цикл
		
		Стр.РасходГород = 0;
		Стр.ОстатокТоплива = 0;
		Стр.ОстатокТоплива1 = 0;
		
	КонецЦикла;
	
	ПересчетТаблицыТоплива(Результат);
	
	Для Каждого Стр Из Результат Цикл
		Если ИсключатьВыходные И Стр.ВидДня <> Перечисления.ВидыДнейПроизводственногоКалендаря.Рабочий Тогда
			Продолжить;
		КонецЕсли;
		
		Если Стр.ОстатокТоплива = 0 И Стр.Получено = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		РаспределятьНаДней = РаспределятьНаДней + 1;
		ПоследнийРабочийДень = Стр;
	КонецЦикла;
	
	ПолученоСумма = Результат.Итог("Получено");
	
	СрЗнач = ПолученоСумма / РаспределятьНаДней;
	
	ШагУменьшения = Окр(СрЗнач / 20, 2);
	
	ОстНаНачало = Неопределено;
	Для Каждого Стр Из Результат Цикл
		МожноРаспределять = Истина;
		Если ИсключатьВыходные И Стр.ВидДня <> Перечисления.ВидыДнейПроизводственногоКалендаря.Рабочий Тогда
			МожноРаспределять = Ложь;
		КонецЕсли;
		
		Если Стр.ОстатокТоплива = 0 И Стр.Получено = 0 Тогда
			МожноРаспределять = Ложь;
		КонецЕсли;
		
		Если МожноРаспределять Тогда
			Стр.РасходГород = СрЗнач;
		КонецЕсли;
		
		Если ОстНаНачало <> Неопределено Тогда
			Стр.ОстатокТоплива = ОстНаНачало;
		КонецЕсли;
		Стр.ОстатокТоплива1 = Стр.ОстатокТоплива + Стр.Получено - Стр.РасходГород;
		ОстНаНачало = Стр.ОстатокТоплива1;
	КонецЦикла;
	
	НормализоватьТаблицу(Результат, ЕмкостьБака, ШагУменьшения);
	
	НужноДобавить = ПолученоСумма - Результат.Итог("РасходГород");
	
	Если НужноДобавить > 0 Тогда
		ПоследнийРабочийДень.РасходГород = ПоследнийРабочийДень.РасходГород + НужноДобавить;
	Иначе
		ПоследнийРабочийДень.РасходГород = ПоследнийРабочийДень.РасходГород + НужноДобавить;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура НормализоватьТаблицу(Результат, ЕмкостьБака, ШагУменьшения)
	
	МаксимальнаяСтрокаНормализации = Неопределено;
	ОстНаНачало = Неопределено;
	КРаспределению = 0;
	Для Счетчик = 0 По Результат.Количество() - 1 Цикл
		ТекСтр = Результат[Счетчик];
		Если ОстНаНачало <> Неопределено Тогда
			ТекСтр.ОстатокТоплива = ОстНаНачало;
		КонецЕсли;
		ТекСтр.ОстатокТоплива1 = ТекСтр.ОстатокТоплива + ТекСтр.Получено - ТекСтр.РасходГород;
		ОстНаНачало = ТекСтр.ОстатокТоплива1;
		
		Если ТекСтр.РасходГород > 0 Тогда
			
			Если МаксимальнаяСтрокаНормализации = Неопределено Тогда
				МаксимальнаяСтрокаНормализации = ТекСтр;
			Иначе
				Если МаксимальнаяСтрокаНормализации.РасходГород <= ТекСтр.РасходГород Тогда
					МаксимальнаяСтрокаНормализации = ТекСтр;
				КонецЕсли;
			КонецЕсли;
			
			Если ТекСтр.ОстатокТоплива1 < 0 Или ТекСтр.РасходГород > ЕмкостьБака Тогда
				МаксимальнаяСтрокаНормализации.РасходГород = МаксимальнаяСтрокаНормализации.РасходГород - ШагУменьшения;
				Счетчик = -1;
				МаксимальнаяСтрокаНормализации = Неопределено;
				ОстНаНачало = Неопределено;
				ПересчетТаблицыТоплива(Результат);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЗ.Дата,
	|	ТЗ.ОстатокТоплива1 КАК ОстатокТоплива1
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	&ТЗ КАК ТЗ
	|ГДЕ
	|	ТЗ.РасходГород = 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МИНИМУМ(ВТ.Дата) КАК Дата,
	|	ВТ.ОстатокТоплива1
	|ПОМЕСТИТЬ ВТ_Груп
	|ИЗ
	|	ВТ КАК ВТ
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ.ОстатокТоплива1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Груп.Дата,
	|	ВТ_Груп.ОстатокТоплива1
	|ИЗ
	|	ВТ_Груп КАК ВТ_Груп
	|ГДЕ
	|	ВТ_Груп.Дата > &Дата";
	
	Запрос.УстановитьПараметр("Дата", НачалоМесяца(Результат[0].Дата));
	Запрос.УстановитьПараметр("ТЗ", Результат);
	РезультатЗапроса = Запрос.Выполнить();
	ТаблицаДат = РезультатЗапроса.Выгрузить();
	ТаблицаДат.Сортировать("Дата");
	
	КРаспределению = Результат.Итог("Получено") - Результат.Итог("РасходГород");
	
	Если КРаспределению > 0 Тогда
		
		ДеньНачалаРаспределения = Неопределено;
		ДеньНачалаРаспределенияНайден = Ложь;
		Счетчик = Результат.Количество() - 1;
		РаспНа = 0;
		Пока Не ДеньНачалаРаспределенияНайден Цикл
			СтрРез = Результат[Счетчик];
			Если СтрРез.ОстатокТоплива1 >= КРаспределению И СтрРез.РасходГород > 0 Тогда
				ДеньНачалаРаспределения = День(СтрРез.Дата) - 1;
				РаспНа = РаспНа + 1;
			ИначеЕсли СтрРез.ОстатокТоплива1 < КРаспределению И СтрРез.РасходГород > 0 Тогда
				ДеньНачалаРаспределенияНайден = Истина;
			КонецЕсли;
			Если Счетчик = 0 Тогда
				ДеньНачалаРаспределения = Результат.Количество() - 1;
				РаспНа = 1;
				Прервать;
			Иначе
				Счетчик = Счетчик - 1;
			КонецЕсли;
		КонецЦикла;
		
		Если ДеньНачалаРаспределения = Неопределено Тогда
			ДеньНачалаРаспределения = 0;
		КонецЕсли;
		
		Для Счетчик = ДеньНачалаРаспределения По Результат.Количество() - 1 Цикл
			
			СтрРез = Результат[Счетчик];
			
			Если РаспНа = 0 Тогда
				Прервать;
			КонецЕсли;
			
			Если СтрРез.РасходГород > 0 Тогда
				СреднееКолво = КРаспределению / РаспНа;
				СтрРез.РасходГород = СтрРез.РасходГород + СреднееКолво;
				РаспНа = РаспНа - 1;
				КРаспределению = КРаспределению - СреднееКолво;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	//Добавление случайности
	ГСЧ = Новый ГенераторСлучайныхЧисел();
	Для Каждого СтрДат Из ТаблицаДат Цикл
		
		СчетчикДат = День(СтрДат.Дата) - 2;
		РаспределениеЗакончено = Ложь;
		Пока Не РаспределениеЗакончено Цикл
			
			Если СчетчикДат <= 0 Тогда
				РаспределениеЗакончено = Истина;
				Продолжить;
			КонецЕсли;
			
			Стр1 = Результат[СчетчикДат];
			Стр2 = Результат[СчетчикДат - 1];
			
			Если Стр1.РасходГород = 0 Или Стр2.РасходГород = 0 Тогда
				РаспределениеЗакончено = Истина;
			Иначе
				РандомЧ = ГСЧ.СлучайноеЧисло(1, 5) / 10 * ШагУменьшения;
				Стр1.РасходГород = Стр1.РасходГород + РандомЧ;
				Стр2.РасходГород = Стр2.РасходГород - РандомЧ;
				СчетчикДат = СчетчикДат - 2;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	ПересчетТаблицыТоплива(Результат);
	
КонецПроцедуры

Процедура ПересчетТаблицыТоплива(ТЗ)
	
	ОстНаНачало = Неопределено;
	Для Счетчик = 0 По ТЗ.Количество() - 1 Цикл
		ТекСтр = ТЗ[Счетчик];
		Если ОстНаНачало <> Неопределено Тогда
			ТекСтр.ОстатокТоплива = ОстНаНачало;
		КонецЕсли;
		ТекСтр.ОстатокТоплива1 = ТекСтр.ОстатокТоплива + ТекСтр.Получено - ТекСтр.РасходГород;
		ОстНаНачало = ТекСтр.ОстатокТоплива1;
	КонецЦикла;
	
КонецПроцедуры


// Конец постобработка ТЗ

Процедура НайтиПодходящиеПутевыеДляНераспределенных(СтрНерас = Неопределено)
