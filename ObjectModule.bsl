	|	И ПутевойЛистВыполнениеЗадания.Ссылка.Водитель <> &Водитель
	|	И ПутевойЛистВыполнениеЗадания.Дата = НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ)
	|	И ПутевойЛистВыполнениеЗадания.Ссылка.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, МЕСЯЦ) И КОНЕЦПЕРИОДА(&Дата, МЕСЯЦ)
	|	И ПутевойЛистВыполнениеЗадания.Ссылка.Организация = &Организация
	|	И ПутевойЛистВыполнениеЗадания.ОстатокТоплива1 < &РазмерБака / 3
	|	И ПутевойЛистВыполнениеЗадания.Ссылка.ГСМ = &ГСМ
	|	И ПутевойЛистВыполнениеЗадания.Водитель.СтатусКатегория = &ЭтоДоставщик
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПутевойЛистВыполнениеЗадания.Ссылка,
	|	ПутевойЛистВыполнениеЗадания.Дата,
	|	ПутевойЛистВыполнениеЗадания.ВидДня,
	|	ПутевойЛистВыполнениеЗадания.ОстатокТоплива,
	|	ПутевойЛистВыполнениеЗадания.ОстатокТоплива1,
	|	ПутевойЛистВыполнениеЗадания.Получено,
	|	ПутевойЛистВыполнениеЗадания.Ссылка.Автомобиль.Автомобиль.НомерЭК,
	|	ПутевойЛистВыполнениеЗадания.Ссылка.ГСМ,
	|	ПутевойЛист.ВсегоПолучено КАК ВсегоПолучено,
	|	ПутевойЛист.РабочихДней,
	|	ПутевойЛист.ВсегоПолучено / ПутевойЛист.РабочихДней КАК коэф
	|ИЗ
	|	Документ.ПутевойЛист.ВыполнениеЗадания КАК ПутевойЛистВыполнениеЗадания
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			СУММА(ПутевойЛист.Получено) КАК ВсегоПолучено,
	|			ПутевойЛист.Ссылка КАК Ссылка,
	|			СУММА(ВЫБОР
	|					КОГДА ПутевойЛист.ВидДня = &ВидДняРабочий
	|						ТОГДА 1
	|					ИНАЧЕ 0
	|				КОНЕЦ) КАК РабочихДней
	|		ИЗ
	|			Документ.ПутевойЛист.ВыполнениеЗадания КАК ПутевойЛист
	|		ГДЕ
	|			ПутевойЛист.Ссылка В(&МассивПутевых)
	|		
