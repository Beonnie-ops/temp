		ТекущаяСтрока.Перерасход  = ТекущаяСтрока.РасходФакт - ТекущаяСтрока.РасходНорма;
		ТекущаяСтрока.ОстатокТоплива  =ТекущаяСтрока.ОстатокТоплива;//ПолучитьОстатокТоплева(,Объект);//ОстатокТоплива;
		Объект.ОстатокТопливаНаНачало  =  ТекущаяСтрока.ОстатокТоплива;
		ТекущаяСтрока.ОстатокТоплива1 = ТекущаяСтрока.ОстатокТоплива + ТекущаяСтрока.Получено - ТекущаяСтрока.РасходФакт;
		
		Если УвеличиватьСпидометрВыходногоДня Тогда
			Если  ТекущаяСтрока.ВидДня = Перечисления.ВидыДнейПроизводственногоКалендаря.Воскресенье
				или ТекущаяСтрока.ВидДня = Перечисления.ВидыДнейПроизводственногоКалендаря.Суббота тогда
				ТекущаяСтрока.КонечныйСпидометр = ТекущаяСтрока.КонечныйСпидометр+Рандом(100,ТекущаяСтрока.ОстатокТоплива1,180);
			КонецЕсли;
		КонецЕсли;
		
		КонечныйСпидометр = ТекущаяСтрока.КонечныйСпидометр;
		ОстатокТоплива  = ТекущаяСтрока.ОстатокТоплива1;
	КонецЕсли;	
	
	Для п = 1  По Объект.ВыполнениеЗадания.Количество()-1 Цикл
		ТекущаяСтрока = Объект.ВыполнениеЗадания[п];
		
		Если КорректироватьНачОстаток Тогда
			Если ТекущаяСтрока.ВидДня = Перечисления.ВидыДнейПроизводственногоКалендаря.Рабочий Тогда
				ТекущаяСтрока.КорректировкаНачальногоСпидометра = ГСЧ.СлучайноеЧисло(1, 5);
			Иначе
				ТекущаяСтрока.КорректировкаНачальногоСпидометра = ГСЧ.СлучайноеЧисло(7, 15);
			КонецЕсли;
		КонецЕсли;
		
		КоэфГород = ?(ТекущаяСтрока.РасходГород<>0, 1, 0);
		КоэфТрасса = ?(ТекущаяСтрока.РасходТрасса<>0, 1, 0);
		
		Если Не РаспределятьАдаптивно Тогда
			
			Если  ТекущаяСтрока.ВидДня <> Перечисления.ВидыДнейПроизводственногоКалендаря.Воскресенье
				и ТекущаяСтрока.ВидДня <> Перечисления.ВидыДнейПроизводственногоКалендаря.Суббота тогда
				Если ТекущаяСтрока.РасходГород=0 и ОстатокТоплива>5 тогда
					ТекущаяСтрока.РасходГород = Рандом(2)	
				конецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
		ТекущаяСтрока.РасстояниеГород =  (ТекущаяСтрока.РасходГород /Объект.РасходТоплива)*100; //* (ТекущаяСтрока.Расстояние-ТекущаяСтрока.РасстояниеТрасса) / 100;
		
		Если КорректироватьПройденноеРасстояние Тогда
			Если ТекущаяСтрока.РасстояниеГород > 200 Тогда
				ПоТрассе = ТекущаяСтрока.РасстояниеГород - 200;
				РасходГород200 = ТекущаяСтрока.РасходГород * 2;
