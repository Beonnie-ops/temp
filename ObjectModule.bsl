			ТекущаяСтрока.МаршрутКуда = "Город";
		КонецЕсли;
		ТекущаяСтрока.РасходНорма = КоэфГород*ТекущаяСтрока.РасходГород + КоэфТрасса*ТекущаяСтрока.РасходТрасса; 
		ТекущаяСтрока.РасходФакт  = ТекущаяСтрока.РасходНорма;	
		ТекущаяСтрока.Перерасход  = ТекущаяСтрока.РасходФакт - ТекущаяСтрока.РасходНорма;
		ТекущаяСтрока.ОстатокТоплива  = ОстатокТоплива;
		ТекущаяСтрока.ОстатокТоплива1 = ТекущаяСтрока.ОстатокТоплива + ТекущаяСтрока.Получено - ТекущаяСтрока.РасходФакт;
		
		Если УвеличиватьСпидометрВыходногоДня Тогда
			Если  ТекущаяСтрока.ВидДня = Перечисления.ВидыДнейПроизводственногоКалендаря.Воскресенье
				или ТекущаяСтрока.ВидДня = Перечисления.ВидыДнейПроизводственногоКалендаря.Суббота тогда
				ТекущаяСтрока.КонечныйСпидометр = ТекущаяСтрока.КонечныйСпидометр+Рандом(100,ТекущаяСтрока.ОстатокТоплива1,180);
			КонецЕсли;
		КонецЕсли;
		
		КонечныйСпидометр = ТекущаяСтрока.КонечныйСпидометр;
		ОстатокТоплива  = ТекущаяСтрока.ОстатокТоплива1;
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьОстатокТоплева(Спидометр=Ложь,Объект)
	
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПутевойЛист.Ссылка,
	|	ПутевойЛист.Дата КАК Дата
	|ПОМЕСТИТЬ Путевые
	|ИЗ
	|	Документ.ПутевойЛист КАК ПутевойЛист
	|ГДЕ
	|	ПутевойЛист.ДатаОкончания < &Дата
	|	И ПутевойЛист.Автомобиль = &Автомобиль
	|	И ПутевойЛист.Организация = &Организация
	|	И ПутевойЛист.ГосНомер = &ГосНомер
	//  |	И ПутевойЛист.ТабНомер = &ТабНомер
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПутевойЛистВыполнениеЗадания.КонечныйСпидометр,
	|	ПутевойЛистВыполнениеЗадания.ОстатокТоплива1 КАК Остаток
	|ИЗ
	|	Путевые КАК Путевые
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПутевойЛист.ВыполнениеЗадания КАК ПутевойЛистВыполнениеЗадания
	|		ПО Путевые.Ссылка = ПутевойЛистВыполнениеЗадания.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПутевойЛистВыполнениеЗадания.Дата УБЫВ");
	
	Запрос.УстановитьПараметр("Дата",Объект.ДатаНачала);
	Запрос.УстановитьПараметр("Автомобиль",Объект.Автомобиль);
	Запрос.УстановитьПараметр("Организация",Объект.Организация);
	Запрос.УстановитьПараметр("ГосНомер",Объект.ГосНомер);
	//Запрос.УстановитьПараметр("ТабНомер",Объект.ТабНомер);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Спидометр Тогда
		Если Выборка.Следующий() Тогда
			Возврат Выборка.КонечныйСпидометр;
		Иначе
			Возврат Объект.НачальныйСпидометр;
		КонецЕсли;
	КонецЕсли;
	Если Выборка.Следующий() И (Объект.ОстатокТопливаНаНачало = 0) Тогда	
		Возврат ?(-0.5<=Выборка.Остаток и Выборка.Остаток<=0.5,0, Выборка.Остаток);	
	КонецЕсли;	
	Возврат Объект.ОстатокТопливаНаНачало;
	
КонецФункции



