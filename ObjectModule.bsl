Функция Рандом(Парам=1,ОстатокТоплива=10, МаксРасход=3.5)
	
	ТекВремя = ТекущаяДата();
	СлЧисло =(Текущаядата() - началоМесяца(Текущаядата()) )/32;
	СлЧисло = число(Прав(стрЗаменить(Формат(СлЧисло, "ЧГ=10"),",",""),5));
	МинимальныйРасход = МинимальныйРасходТоплива*1000+1933;///2.5*100;	
	МаксимальныйРасход =Макс(ОстатокТоплива,МаксРасход)*1000;	
	ГСЧ = Новый ГенераторСлучайныхЧисел(0);
	СлучайноеЧисло = ГСЧ.СлучайноеЧисло(МинимальныйРасход, МаксимальныйРасход) ;
	Случай = СлучайноеЧисло+СлЧисло/35333;
	Случай=(1803*парам*Случай)%2197983647;

	Возврат(Случай/10000000);
КонецФункции   

Функция ДоСледующейЗаправки(ТЗ,К,РабочихДней =ЛОжь)
	КК =К;
	Если ((ТЗ.Количество()-1>КК)
		//и(КК>=1)
		) Тогда
		Н=0;                           
		КК=КК+1;
		Пока КК<=ТЗ.Количество()-1 Цикл
			СтрТЗ =	ТЗ[КК];//.ПолучитьСтрокуПоНомеру(К);
			Если РабочихДней тогда
				Если СтрТЗ.ВидДня <> Перечисления.ВидыДнейПроизводственногоКалендаря.Рабочий тогда
					КК=КК+1;
					Продолжить;
				КонецЕсли;	
			КОнецЕсли;	
			Если СтрТЗ.Получено<>0 Тогда
				Прервать;
			КонецЕсли;
			Н=Н+1;
			КК=КК+1;			
		КонецЦикла;      
		возврат Н;
	КонецЕсли;    
	возврат -1;
КонецФункции   

