Процедура КоманднаяПанель2СоздатьПутевой(Кнопка)
	// Вставить содержимое обработчика.
	ТекД = ЭлементыФормы.карты.ТекущиеДанные;
	если не ЗначениеЗаполнено(ТекД.ПутевойЛист) тогда 
		СсылкаНаДокумент   = 	  СоздатьПутевой(ТекД);
		ТекД.ПутевойЛист = СсылкаНаДокумент;
	КонецЕсли;
	Если не ТекД.ПутевойЛист.Пустая() тогда
		ЗаполнитьДокументуПоТабелю(ТекД);
		СсылкаНаДокумент =ТекД.ПутевойЛист;
	КонецЕсли;	 
	ОткрытьЗначение(СсылкаНаДокумент);
КонецПроцедуры

Функция СоздатьПутевой(ТекСрока = Неопределено)
	Если  ТекСрока <> Неопределено тогда
		НовыйДокумент = Документы.ПутевойЛист.СоздатьДокумент();
		//	НовыйДокумент.Номер = "111";
		НовыйДокумент.Организация        = Организация;
		НовыйДокумент.НомерПутевого      = Формат(ТекСрока.Период, "ДФ=MM")+"/"+СокрЛП(ТекСрока.Водитель.Код);
		НовыйДокумент.Комментарий        = СокрЛП(ТекСрока.НомерЭК);
		НовыйДокумент.Дата               = КонецМесяца(ТекСрока.Период);
		//НовыйДокумент.Автомобиль = НайтиАвтомобильОСпоВодителю(ТекСрока.Водитель);
		//За одним водителем может быть несколько автомобилей будем искать по ТК и ОС
		
		НовыйДокумент.Автомобиль          = НайтиАвтомобильОСпоАвтомобилю(ТекСрока.Автомобиль); 
		НовыйДокумент.Марка               = ТекСрока.Автомобиль;
		НовыйДокумент.ГосНомер            = ТекСрока.Автомобиль.ГосНомер;
		НовыйДокумент.РасходТоплива       = ТекСрока.Автомобиль.РасходТоплива;
		НовыйДокумент.РасходТопливаТрасса = ТекСрока.Автомобиль.РасходТопливаТрасса;
		
		НовыйДокумент.ДатаНачала         = НачалоМесяца(ТекСрока.Период);
		НовыйДокумент.ДатаОкончания      = КонецМесяца(ТекСрока.Период);
		
		НовыйДокумент.ТабНомер           = ТекСрока.Водитель.Код;
		НовыйДокумент.Водитель           = ТекСрока.Водитель;
		НовыйДокумент.ГСМ                = ТекСрока.Автомобиль.ГСМ; 
		НовыйДокумент.НачальныйСпидометр = ПолучитьОстатокТоплева(Истина,НовыйДокумент);
		НовыйДокумент.Ответственный      = глЗначениеПеременной("глТекущийПользователь");

		НовыйДокумент.Записать();
		
		Возврат НовыйДокумент.Ссылка;
	конецЕсли;
	
	
	
КонецФункции

