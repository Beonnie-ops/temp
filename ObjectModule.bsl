Функция  ВыполнитьЗапросПроизвКалендаря(Объект)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаНач",Объект.ДатаНачала);
	Запрос.УстановитьПараметр("ДатаКон",Объект.ДатаОкончания);
	Запрос.УстановитьПараметр("Водитель",Объект.Водитель);
	Запрос.Текст = "ВЫБРАТЬ
	|	РегламентированныйПроизводственныйКалендарь.ДатаКалендаря КАК Дата,
	|	РегламентированныйПроизводственныйКалендарь.ВидДня,
	|	&Водитель КАК Водитель,
	|	""По городу"" КАК МаршрутОткуда,
	|	""По городу"" КАК МаршрутКуда
	|ИЗ
	|	РегистрСведений.РегламентированныйПроизводственныйКалендарь КАК РегламентированныйПроизводственныйКалендарь
	|ГДЕ
	|	РегламентированныйПроизводственныйКалендарь.ДатаКалендаря МЕЖДУ &ДатаНач И &ДатаКон";
	возврат Запрос.Выполнить().Выгрузить();
КонецФункции	


Процедура ЗаполнитьНаСервере(ИмяКоманды = Неопределено,Объект)
	Объект.ВыполнениеЗадания.Загрузить(ВыполнитьЗапросПроизвКалендаря(Объект));
	Если ИмяКоманды = "Заполнить33" Тогда
		ит = 0;
		Для Каждого стр из Объект.ВыполнениеЗадания Цикл
			пДень = Ит % 6 + 1;
			Если пДень <= 3 Тогда
				стр.ВидДня = Перечисления.ВидыДнейПроизводственногоКалендаря.Рабочий;
			Иначе
				стр.ВидДня = ?(ДеньНедели(стр.Дата) = 6,Перечисления.ВидыДнейПроизводственногоКалендаря.Суббота,перечисления.ВидыДнейПроизводственногоКалендаря.Воскресенье);
			КонецЕсли;
			Ит = Ит + 1;
		КонецЦикла;
	ИначеЕсли ИмяКоманды = "1С7" Тогда
		Для Каждого стр из Объект.ВыполнениеЗадания Цикл
			Если МассивДат.НайтиПоЗначению(стр.Дата) = Неопределено Тогда
				стр.ВидДня = ?(ДеньНедели(стр.Дата) = 6,Перечисления.ВидыДнейПроизводственногоКалендаря.Суббота,перечисления.ВидыДнейПроизводственногоКалендаря.Воскресенье);
			Иначе
				стр.ВидДня = Перечисления.ВидыДнейПроизводственногоКалендаря.Рабочий;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры




