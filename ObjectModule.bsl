Функция НайтиАтомобиль(НомерЭК,ГСМ,МассивОшибок)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Автомобили.Ссылка,
	|	Автомобили.ГСМ
	|ИЗ
	|	Справочник.Автомобили КАК Автомобили
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОсновныеСредства КАК ОсновныеСредства
	|		ПО Автомобили.Ссылка = ОсновныеСредства.Автомобиль
	|ГДЕ
	|	Автомобили.НомерЭК = &НомерЭК
	|	И Автомобили.ПометкаУдаления = ЛОЖЬ
	|	И НЕ ОсновныеСредства.Ссылка ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("НомерЭК", Число(НомерЭК));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	колЗ = ВыборкаДетальныеЗаписи.Количество();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если колЗ=1 тогда
			Возврат ВыборкаДетальныеЗаписи.Ссылка;
		ИначеЕсли ВыборкаДетальныеЗаписи.ГСМ =ГСМ тогда
			Возврат ВыборкаДетальныеЗаписи.Ссылка;
		КонецЕсли;
	КонецЦикла;
	ТекстОшибки = "В справочнике Автомобили не найдена карта с № "+НомерЭК + " с топливом "+Строка(ГСМ);
	Если МассивОшибок.Найти(ТекстОшибки)= Неопределено тогда
		МассивОшибок.добавить(ТекстОшибки);
	КонецЕсли;	
	//сообщить(ТекстОшибки) ;
	Возврат Неопределено;	
конецФункции	

Процедура ВыполнитьЗагрузкиИзФаилавТЗ()
	ПутьКФайлу="";
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок = "Выбор файла";
	Диалог.Фильтр = "Текстовые файлы(*.txt;*.txt)|*.txt;*.txt";
	Диалог.ИндексФильтра = 0;
	Диалог.ПредварительныйПросмотр = Ложь;
	Диалог.ПроверятьСуществованиеФайла = Истина;
	Диалог.МножественныйВыбор = Ложь; 
	Диалог.ПолноеИмяФайла = ПутьКФайлу;
	
	Если Диалог.Выбрать() Тогда
		ПутьКФайлу = Диалог.ПолноеИмяФайла;
	КонецЕсли;
	
	НачалоПериода  = ТекущаяДата();
	КонецПериода   = ТекущаяДата();
	
	стр = "" ;
	УНН="";
	Получатель=ложь;
	Если ПутьКФайлу<>"" тогда
		Заправки.Очистить();
		Текст = Новый ЧтениеТекста(ПутьКФайлу,КодировкаТекста.ANSI);
		Пока стр <> Неопределено Цикл
			стр = Текст.ПрочитатьСтроку()    ;
			
			Если Найти(Стр,"за период с 20")<>0 тогда
				Массив =	СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Стр," ");
				год = Лев(Массив[3],4);
				МесяцН = сред(Массив[3],6,2)  ;
				ДеньН = прав(Массив[3],2);	
				НачалоПериода = Дата(год,МесяцН,ДеньН)  ;
				
				МесяцК = сред(Массив[5],6,2)  ;
				ДеньК = прав(Массив[5],2);	
				КонецПериода = Дата( Лев(Массив[5],4),МесяцК,ДеньК)  ;
				
			ИначеЕсли  УНН="" тогда
				Если 	Найти(Стр,"Получатель:")<>0  тогда
					Получатель=истина;
				ИначеЕсли Найти(Стр,"УНН")<>0 и Получатель тогда
					Массив =	СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Стр," ");
					
					Если Массив[3] ="УНК" Тогда
						Организация =  Справочники.Организации.НайтиПоРеквизиту("ИНН",Массив[2])
					Иначе	
						Организация =  Справочники.Организации.НайтиПоРеквизиту("ИНН",Массив[3]);
					КонецЕсли; 
					
					Прервать;	
				КонецЕсли;	
			конецЕсли;	
			
			
		КонецЦикла;		
		
		
		Если Организация.Пустая() тогда
			Предупреждение("Не найдена Органозация, не загрузится.");
			возврат;
		КонецЕсли;   
		МассивОшибок = новый Массив;
	
		стр = "" ;
		Пока стр <> Неопределено Цикл
			стр = Текст.ПрочитатьСтроку()    ;
			//Попытка
			//	День = Число(Лев(стр,2));
			//	Месяц = Число(Сред(Стр,4,2));
			//	Год = Число(Прав(стр,2));
			//Исключение
			//КонецПопытки;
			//Массивдат.Добавить(Дата(2000+Год,Месяц,День));
			
			Если Найти(Стр,"ИТОГО")<>0 тогда
				Прервать;
			конецЕсли;
			
			Если  Найти(Стр,"Итого по н/п") <>0 тогда
				//НомерЭК=Неопределено;
				Продолжить;
			КонецЕсли;	
			
			Если  Найти(Стр,"Итого по э/к") <>0 тогда
				НомерЭК=Неопределено;
				Продолжить;
			КонецЕсли;	

			
			
			ЕСли врег(лев(СокрЛП(стр),3))="Э/К" тогда
				Состояние(стр);
				Массив =	СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Стр," ");
				НомерЭК= Массив[1];
				Если Найти("0123456789",Лев(номерЭК,1))=0 тогда
					продолжить;
				КонецЕсли;	
				Продолжить;
			КонецЕсли;
			
			Если НомерЭК<>Неопределено тогда
				Массив =	СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Стр," ");
				если Массив.количество()<8 Тогда
					Продолжить;	
				конецЕсли;
				
				//Если сокрЛП(НомерЭК)<>"653000168" тогда
				//	Продолжить;
				//КонецЕсли;
				////	Год  = год(ТекущаяДата());
				Месяц = Лев(Массив[0],2)    ;
				день = прав(Массив[0],2);
				Время = Число(СтрЗаменить(Массив[1],":",","));
				СтрЗ =	Заправки.Добавить();
				
				Если  Найти(Массив[9],"АИ-95")<> 0 тогда 
					//Массив[9]="АИ-95-K5" или Массив[9]="АИ-95-К5" или  Массив[9]="АИ-95-К5-Е" тогда
					СтрЗ.ГСМ = Справочники.Номенклатура.НайтиПоКоду("ШПЧ00006552");//НайтиПоНаименованию("АИ-95",истина);
				ИначеЕсли Найти(Массив[9],"ДТ-")<> 0 тогда 
					// Массив[9]="ДТ-Л-К5"  тогда
					СтрЗ.ГСМ = Справочники.Номенклатура.НайтиПоКоду("ШПЧ00006548");
				ИначеЕсли  Найти(Массив[9],"АИ-92")<> 0 тогда 
                    // Массив[9]="АИ-92-К5"  тогда
					СтрЗ.ГСМ = Справочники.Номенклатура.НайтиПоКоду("ШПЧ00006551");//НайтиПоНаименованию("АИ-92",истина);
				ИначеЕсли  Найти(Массив[9],"АИ-98")<> 0 тогда 
                    // Массив[9]="АИ-92-К5"  тогда
					СтрЗ.ГСМ = Справочники.Номенклатура.НайтиПоКоду("ЭКС00001094");//НайтиПоНаименованию("АИ-98",истина);
			
				КонецЕсли;
				СтрЗ.НомерЭК    = НомерЭК ;
				СтрЗ.Автомобиль = НайтиАтомобиль(НомерЭК,СтрЗ.ГСМ,МассивОшибок);///Автомобиль;	
				СтрЗ.Водитель   = СтрЗ.Автомобиль.Водитель;
				СтрЗ.Время      = Время;
				СтрЗ.Дата       = Дата(год,месяц,день);
				СтрЗ.Период     = НачалоМесяца(СтрЗ.Дата);
				СтрЗ.Получено   = Массив[5];
				СтрЗ.Сумма      = Массив[7];
						
				//стрз.ГСМ =  СтрЗ.Автомобиль.ГСМ;   АИ-92-К5
				//ИначеЕсли  УНН="" тогда
				//	Если 	Найти(Стр,"Получатель:")<>0  тогда
				//		Получатель=истина;
				//	ИначеЕсли Найти(Стр,"УНН")<>0 и Получатель тогда
				//		Массив =	СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Стр," ");
				//		Организация =  Справочники.Организации.НайтиПоРеквизиту("ИНН",Массив[3]);
				//	КонецЕсли;	
			конецЕсли;	
			
			
		КонецЦикла;
		Текст.Закрыть();
		
		для каждого стр из МассивОшибок цикл
		Сообщить(стр);	
		КонецЦикла;	
		
	КонецЕсли;
	тз =	Заправки.Выгрузить(,"НомерЭК,Водитель,Период,ГСМ,Автомобиль");
	ТЗ.Свернуть("НомерЭК,Водитель,Период,ГСМ,Автомобиль","");
	Карты.Загрузить(ТЗ);
	
	Если ТЗ.Количество()<>0 тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЗ.Водитель,
		|	ТЗ.НомерЭК,
		|	НАЧАЛОПЕРИОДА(ТЗ.Период, МЕСЯЦ) КАК Период,
		|	ТЗ.ГСМ,
		|	ТЗ.Автомобиль
		|ПОМЕСТИТЬ ТЗ
		|ИЗ
		|	&ТЗ КАК ТЗ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЗ.Водитель КАК Водитель,
		|	ТЗ.НомерЭК КАК НомерЭК,
		|	ВложенныйЗапрос.Ссылка КАК ПутевойЛист,
		|	ТЗ.Период,
		|	ТЗ.ГСМ,
		|	ТЗ.Автомобиль
		|ИЗ
		|	ТЗ КАК ТЗ
		|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			ПутевойЛист.Ссылка КАК Ссылка,
		|			ПутевойЛист.Водитель КАК Водитель,
		|			НАЧАЛОПЕРИОДА(ПутевойЛист.Дата, МЕСЯЦ) КАК Период
		|		ИЗ
		|			Документ.ПутевойЛист КАК ПутевойЛист
		|		ГДЕ
		|			ПутевойЛист.Организация = &Организация
		|           и ПутевойЛист.Водитель <> &ВодительПустая
		|			И ПутевойЛист.Дата МЕЖДУ &НачалоПериода И &КонецПериода
		|			И (ПутевойЛист.Водитель, НАЧАЛОПЕРИОДА(ПутевойЛист.Дата, МЕСЯЦ)) В
		|					(ВЫБРАТЬ
		|						ТЗ.Водитель,
		|						ТЗ.Период
		|					ИЗ
		|						ТЗ КАК ТЗ)
		|			И ПутевойЛист.ПометкаУдаления = ЛОЖЬ) КАК ВложенныйЗапрос
		|		ПО ТЗ.Водитель = ВложенныйЗапрос.Водитель
		|			И ТЗ.Период = ВложенныйЗапрос.Период";
		
		Запрос.УстановитьПараметр("Организация", Организация);
		Запрос.УстановитьПараметр("ТЗ", ТЗ);
		Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(НачалоПериода));
		Запрос.УстановитьПараметр("КонецПериода", КонецДня(КонецПериода));
			Запрос.УстановитьПараметр("ВодительПустая", Справочники.ФизическиеЛица.ПустаяСсылка());

		
		Карты.Очистить();
		ТЗ1 = Запрос.Выполнить().Выгрузить();
		Если ТЗ1.Количество()<>0 тогда
			для каждого стр из ТЗ1 цикл
				ОтборК= Новый Структура("НомерЭК,Водитель,Период",стр.НомерЭК,стр.Водитель,стр.Период);  
				СТрокиОтбК= Карты.НайтиСтроки(ОтборК);
				Если СТрокиОтбК.Количество()<>0 Тогда
					продолжить;	
				КонецЕсли;	
				ТзК = Карты.Добавить();	
				ЗаполнитьЗначенияСвойств(ТзК,стр);
			КонецЦикла;
			//Карты.Загрузить(ТЗ1);
		КонецЕсли;
		состояние("Создание новых документов ПЛ.");
		для каждого стр из Карты цикл
			ТекД = стр;
			Если стр.Водитель.Пустая() тогда
				продолжить;
			конецЕсли;	
			если не ЗначениеЗаполнено(ТекД.ПутевойЛист) тогда 
				СсылкаНаДокумент   = 	  СоздатьПутевой(ТекД);
				ТекД.ПутевойЛист = СсылкаНаДокумент;
			КонецЕсли;
			//Если не ТекД.ПутевойЛист.Пустая() тогда
			//	ЗаполнитьДокументуПоТабелю(ТекД.ПутевойЛист);
			//КонецЕсли;	 
		КонецЦикла;
		
		
		
	конецЕсли;
	
	
	Сообщить("Загружен файл "+ПутьКФайлу);
	
	
	
КонецПроцедуры

Процедура ОтборПоНомеруКарты(ИмяРеквизитаСписка,ИмяОтбора,НомерКарты);
	ЭлементыФормы[ИмяРеквизитаСписка].ОтборСтрок[ИмяОтбора].ВидСравнения  = ВидСравнения.Равно;
	ЭлементыФормы[ИмяРеквизитаСписка].ОтборСтрок[ИмяОтбора].Использование = Истина;
	ЭлементыФормы[ИмяРеквизитаСписка].ОтборСтрок[ИмяОтбора].Значение      = НомерКарты;
	
КонецПроцедуры	


Процедура КоманднаяПанель1ЗагрузитьИзФаила(Кнопка)
	// Вставить содержимое обработчика.
	
	ЗаправкиНеРаспределенные.Очистить();
	ВыполнитьЗагрузкиИзФаилавТЗ();
	Если Карты.Количество()<>0 тогда
		ЭлементыФормы.Карты.ТекущаяСтрока = Карты[Карты.Количество()-1];  
		текс  = ЭлементыФормы.Карты.ТекущиеДанные;
		//ОтборПоНомеруКарты("Карты","НомерЭК","652014565");
		
		ОтборПоНомеруКарты("Заправки","НомерЭК",текс.НомерЭК);
		ОтборПоНомеруКарты("Заправки","Период",текс.Период);
		
		
	КонецЕсли;
	
	//ЭлементыФормы.Заправки.Колонки.Получено.ТекстПодвала = Заправки.Итог("Получено");
	ОбновитьПодвалЗаправкиПолучено();

	
КонецПроцедуры

Процедура КартыПриАктивизацииСтроки(Элемент)
	
	текс  = ЭлементыФормы.Карты.ТекущиеДанные;
	ОтборПоНомеруКарты("Заправки","НомерЭК",текс.НомерЭК);
	ОтборПоНомеруКарты("Заправки","Период",текс.Период);
	
	ОбновитьПодвалЗаправкиПолучено();
	
КонецПроцедуры

Процедура КоманднаяПанельДокументыДляИмпортаУстановитьФлажки(Кнопка)
	
	Для Каждого СтрокаДокумента из Карты Цикл
		СтрокаДокумента.Пометка = Истина;
	КонецЦикла;
	
КонецПроцедуры

Процедура КоманднаяПанельДокументыДляИмпортаСнятьФлажки(Кнопка)
	
	Для Каждого СтрокаДокумента из Карты Цикл
		СтрокаДокумента.Пометка = Ложь;
