		или Организация.ИНН = "193139549"//Акинита
		или Организация.ИНН = "100230639" // Зорина
		или Организация.ИНН = "193631798" // БрайтСтор 
		тогда
		Сотр = новый ТаблицаЗначений;
		Сотр.Колонки.Добавить("Наименование", ОбщегоНазначения.ПолучитьОписаниеТиповСтроки(100));
		Сотр.Колонки.Добавить("КодСотрудника",ОбщегоНазначения.ПолучитьОписаниеТиповСтроки(20));
		стсрС = Сотр.Добавить();
		стсрС.КодСотрудника = СокрЛП(ПЛ.Водитель.Код);
		стсрС.Наименование = СокрЛП(ПЛ.Водитель.Наименование);
		
		Если ПолучитьТабельСотрудника1с8ЗУП(Сотр,ПЛ.ДатаНачала,ПЛ.ДатаОкончания) тогда
			Есть = "Записан";	
		КонецЕсли;
		
	Иначе
		Если ЕстьПодключение=ложь тогда        
			ПодключитьБазу() ;
		КонецЕсли;
		Если ЕстьПодключение=Истина тогда
			ДатаНачала = ПЛ.ДатаНачала;
			Год = Формат(Год(ДатаНачала), "ЧН=0; ЧГ=");
			Месяц = Месяц(ДатаНачала);
			ТабНомСотр = СокрЛП(ПЛ.Водитель.Код);
			Есть =  База.EvalExpr("ПолучитьТабельСотрудника("""+ТабНомСотр+""","+Год+","+Месяц+")");
		КонецЕсли;	
	КонецЕсли;		
	
	Если Найти(Есть,"Записан")<>0 тогда
		ОбъектПЛ = ПЛ.получитьОбъект();
		Если  ОбъектПЛ.Автомобиль.пустая() тогда
			ОбъектПЛ.Автомобиль =      НайтиАвтомобильОСпоВодителю(ОбъектПЛ.Водитель.ссылка);
		конецЕсли;
		Если ОбъектПЛ.ВыполнениеЗадания.Количество() <> 0 Тогда
			Если (ПерераспределятьПроведенные и ОбъектПЛ.Проведен) или не ОбъектПЛ.Проведен тогда
				ОбъектПЛ.ВыполнениеЗадания.Очистить();
			Иначе
				Если Вопрос("Перезаполнить данные? таблица будет очищена! "+Строка(ОбъектПЛ),РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Да Тогда
					ОбъектПЛ.ВыполнениеЗадания.Очистить();
				КонецЕсли;
			конецЕсли;
		КонецЕсли;
		ДатаУвольнения="";
		ЗаполнитьИз1С_7_8_НаСервере(ОбъектПЛ,ДатаУвольнения);
		ТекД.ДатаУвольнения =ДатаУвольнения;
		ПересчетСпидометра(ОбъектПЛ);
		ОбъектПЛ.записать();
	иначе
		Сообщить(Есть+", карта № "+строка(ПЛ.Водитель));
	КонецЕсли;
	
	
КонецПроцедуры

Процедура ПересчетСпидометра(Объект, КорректироватьНачОстаток = Ложь, КорректироватьПройденноеРасстояние = Ложь)
	ОстатокТоплива = 0;КонечныйСпидометр = 0;
	ДопрРасходНачало=0;
	ДопрРасходНачало1=0;
	ГСЧ = Новый ГенераторСлучайныхЧисел();
	Если Объект.ВыполнениеЗадания.Количество() > 0 Тогда
		Объект.ДопКолКМ = Объект.Автомобиль.Автомобиль.РасстояниеДоДома*2;
		ТекущаяСтрока = Объект.ВыполнениеЗадания[0];
		
		Если КорректироватьНачОстаток Тогда
			Если ТекущаяСтрока.ВидДня = Перечисления.ВидыДнейПроизводственногоКалендаря.Рабочий Тогда
				ТекущаяСтрока.КорректировкаНачальногоСпидометра = ГСЧ.СлучайноеЧисло(1, 5);
			Иначе
				ТекущаяСтрока.КорректировкаНачальногоСпидометра = ГСЧ.СлучайноеЧисло(7, 15);
			КонецЕсли;
		КонецЕсли;
		
		КоэфГород = ?(ТекущаяСтрока.РасходГород<>0, 1, 0); //20220320. Павел
		КоэфТрасса = ?(ТекущаяСтрока.РасходТрасса<>0, 1, 0);
		ТекущаяСтрока.РасстояниеГород =  (ТекущаяСтрока.РасходГород /Объект.РасходТоплива)*100;
		
		Если КорректироватьПройденноеРасстояние Тогда
			Если ТекущаяСтрока.РасстояниеГород > 200 Тогда
				ПоТрассе = ТекущаяСтрока.РасстояниеГород - 200;
				РасходГород200 = ТекущаяСтрока.РасходГород * 2;
				ТекущаяСтрока.РасходГород = РасходГород200;
				ТекущаяСтрока.РасстояниеГород = 200;
				ТекущаяСтрока.РасстояниеТрасса = ПоТрассе;
				ТекущаяСтрока.РасходТрасса = ТекущаяСтрока.РасстояниеТрасса * Объект.РасходТопливаТрасса / 100;
				ТекущаяСтрока.МаршрутКуда = "Трасса";
				ТекущаяСтрока.МаршрутОткуда = "Трасса";
			КонецЕсли;
		КонецЕсли;
		
		Если  Объект.ДопКолКМ = 0 тогда
			ДопрРасходНачало1 = 	Макс(рандом(10),Рандом(12));
		Иначе
			рр=1;
			пока ДопрРасходНачало=ДопрРасходНачало1 Цикл 
				Если РР%11 =0 тогда	
					прервать;
				КонецЕсли;	
				рр=рр+1;	
				ДопрРасходНачало1 = 	Макс(Мин(Объект.ДопКолКМ+рандом(2),Рандом(Объект.ДопКолКМ+1)),Рандом(Объект.ДопКолКМ))
			КонецЦикла;
		КонецЕсли;	
		
		Если ДопрРасходНачало=ДопрРасходНачало1 тогда
			ДопрРасходНачало =ДопрРасходНачало1+ рандом(1) ;
		Иначе 
			ДопрРасходНачало =ДопрРасходНачало1;
		КонецЕсли;
		
		//ТекущаяСтрока.РасстояниеГород =   Объект.РасходТоплива * (ТекущаяСтрока.Расстояние-ТекущаяСтрока.РасстояниеТрасса) / 100;
		//Если    Объект.НачальныйСпидометр=0 тогда
		Если КорректироватьНачОстаток Тогда
			Объект.НачальныйСпидометр = ПолучитьОстатокТоплева(Истина,Объект) + Объект.ДопКолКМ;
		Иначе
			Объект.НачальныйСпидометр = ПолучитьОстатокТоплева(Истина,Объект);
		КонецЕсли;
		
		//КонецЕсли;
		
		ТекущаяСтрока.НачальныйСпидометр = Объект.НачальныйСпидометр + ТекущаяСтрока.КорректировкаНачальногоСпидометра + Объект.ДопКолКМ;
		ТекущаяСтрока.КонечныйСпидометр = ТекущаяСтрока.НачальныйСпидометр + ТекущаяСтрока.РасстояниеГород +ТекущаяСтрока.РасстояниеТрасса;	
		ТекущаяСтрока.Расстояние  = ТекущаяСтрока.РасстояниеГород +ТекущаяСтрока.РасстояниеТрасса;
		
		//ТекущаяСтрока.РасходГород = Объект.РасходТоплива * (ТекущаяСтрока.Расстояние-ТекущаяСтрока.РасстояниеТрасса) / 100;
		//ТекущаяСтрока.РасходТрасса = Объект.РасходТопливаТрасса * ТекущаяСтрока.РасстояниеТрасса / 100; //20220305. Павел
		Если ТекущаяСтрока.РасстояниеТрасса <> 0 Тогда
			ТекущаяСтрока.МаршрутОткуда = "Трасса";
