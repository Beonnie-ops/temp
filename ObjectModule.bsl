КонецПроцедуры


Процедура КоманднаяПанель2ЗагрузитьВдокументы(Кнопка)
	ЗаправкиНеРаспределенные.Очистить();
	
	ЗПр=  Заправки.Выгрузить();
	ЗПр.ЗаполнитьЗначения("","ПутевойЛист");
	Заправки.Загрузить(ЗПР);
	ЗПР="";
	Если НеОбновлятьТабельныеДанные = ложь тогда
		для каждого стр из Карты цикл
			ТекД = стр;
			Если стр.Водитель.Пустая() или стр.Пометка=Ложь тогда
				продолжить;
			конецЕсли;	
			Если не ТекД.ПутевойЛист.Пустая() тогда
				ЗаполнитьДокументуПоТабелю(ТекД);
			КонецЕсли;	 
		КонецЦикла;
	КонецЕсли;
	
	//НеобращатьВниманиенаВидТоплива Для холдинга = истина
	//Костыль чтобы не трогать алгоритм 
	
	НеОбращатьВниманиенаВидТоплива = Истина;

	для каждого стр из Карты цикл 
		Если стр.Пометка=Истина тогда
			Если стр.ПутевойЛист.Пустая() тогда
				Продолжить;
			конецЕсли;	
			ЭтоДоставщик =	стр.Водитель.СтатусКатегория = справочники.КатегорииЗастрахованныхЛиц.НайтиПоНаименованию("Доставка");

			Есть=ложь;

			ТЗпл = стр.ПутевойЛист.ВыполнениеЗадания.Выгрузить();
			ТЗпл.ЗаполнитьЗначения(0,"Получено");
			отбор = Новый Структура("НомерЭК,Период",стр.НомерЭК,стр.Период);
			стрЗаправки = Заправки.НайтиСтроки(отбор); 
			Для каждого стрЗ из стрЗаправки цикл
				отборПЛ  = Новый Структура("Дата",стрЗ.Дата);
				стрПЛ    = ТЗпл.НайтиСтроки(отборПЛ);
				ЕстьДата = Ложь;
				Если стр.ДатаУвольнения<>Дата(1,1,1) и стр.ДатаУвольнения< стрЗ.Дата тогда
					Сообщить(строка(стрЗ.Дата) + " - Топливо заправки. "+стрЗ.НомерЭК+" Исключена, дата увольненеия "+стр.ДатаУвольнения+" № "+ Строка(стр.ПутевойЛист) );
					
					стрЗР             =	ЗаправкиНеРаспределенные.Добавить();
					стрЗР.Автомобиль  = стрЗ.Автомобиль;
					стрЗР.Водитель    = стрЗ.Водитель;
					стрЗР.Дата        = стрЗ.Дата;
					стрЗР.ГСМ         = стрЗ.ГСМ;
