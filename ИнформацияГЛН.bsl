Процедура ЗаписатьИнфрмациюПоГоловномуГЛНИПполучитьДатыДействия() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Организации.GLN КАК ГЛН,
		|	Организации.Ссылка КАК ОрганизацияДляПроверки
		|ИЗ
		|	Справочник.Организации КАК Организации
		|ГДЕ
		|	Организации.GLN <> """"";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ПолучитьЗаписатьГЛНПоОсновномуГЛН(Выборка.ОрганизацияДляПроверки, Выборка.ГЛН);
	
		ОбновитьСрокиДействияГЛН(Выборка.ОрганизацияДляПроверки);
		
	КонецЦикла;

	
КонецПроцедуры

Процедура ПолучитьЗаписатьГЛНПоОсновномуГЛН(ОрганизацияДляПроверки, ГЛНДляПроверки) Экспорт

	Результат = КоннекторHTTP.КакТекст(КоннекторHTTP.Get("https://ext.epass.by/epassorgglns?SearchGln.Gln=" + ГЛНДляПроверки));

	МассивОрганизаций = МассивОрганизаций(Результат);
	
	Для Каждого Стр Из МассивОрганизаций Цикл
	//	Сообщить(Стр.GLN + " - " + Стр.КраткоеНаимен + " - " + Стр.Адрес);
		
		Набор = РегистрыСведений.ИнформацияГЛН.СоздатьНаборЗаписей();
		
		Набор.Отбор.Организация.Установить(ОрганизацияДляПроверки);
		Набор.Отбор.ГЛН.Установить(Стр.GLN);
		Набор.Отбор.Адрес.Установить(Стр.Адрес);
		
		Набор.Прочитать();
		Набор.Очистить();
		
		Новая = Набор.Добавить();
		Новая.Организация = ОрганизацияДляПроверки;
		Новая.ГЛН = Стр.GLN;
		Новая.Адрес = Стр.Адрес;
			
		Новая.ДатаЗагрузкиДанных = ТекущаяДата();
		
		Набор.Записать();
		
	КонецЦикла;
		
КонецПроцедуры

Функция МассивОрганизаций(Результат)
	
	ИсходныйТекстHTML = Результат;
	// Шаг 1. Инициализируем чтение и DOM-модель
	ЧтениеHTML = Новый ЧтениеHTML;
	ЧтениеHTML.УстановитьСтроку(ИсходныйТекстHTML);
	
	ПостроительDOM = Новый ПостроительDOM;
	ДокументDOM = ПостроительDOM.Прочитать(ЧтениеHTML); 
	ЧтениеHTML.Закрыть();
	
	// Шаг 2. Находим таблицы на странице
	СписокТаблиц = ДокументDOM.ПолучитьЭлементыПоИмени("table");
	Если СписокТаблиц.Количество() = 0 Тогда
		ВызватьИсключение "Таблица с данными не найдена на странице!";
	КонецЕсли;
	
	// Извлекаем первую таблицу через метод Элемент()
	ТаблицаДанных = СписокТаблиц.Элемент(0); 
	СписокСтрок = ТаблицаДанных.ПолучитьЭлементыПоИмени("tr");
	
	МассивОрганизаций = Новый Массив;
	
	// Шаг 3. Перебираем строки таблицы с помощью "Для Каждого"
	Для Каждого СтрокаТЧ Из СписокСтрок Цикл
		
		// Находим ячейки (td) внутри текущей строки
		СписокЯчеек = СтрокаТЧ.ПолучитьЭлементыПоИмени("td");
		
		// Если ячеек нет (например, строка заголовков th), пропускаем её
		Если СписокЯчеек.Количество() < 6 Тогда
			Продолжить;
		КонецЕсли;
		
		// Заполняем структуру данными из ячеек через метод .Элемент()
		ОрганизацияГЛН = Новый Структура;
		ОрганизацияГЛН.Вставить("Номер",        СокрЛП(СписокЯчеек.Элемент(0).ТекстовоеСодержимое));
		ОрганизацияГЛН.Вставить("GLN",          СокрЛП(СписокЯчеек.Элемент(1).ТекстовоеСодержимое));
		ОрганизацияГЛН.Вставить("Наименование", СокрЛП(СписокЯчеек.Элемент(2).ТекстовоеСодержимое));
		ОрганизацияГЛН.Вставить("КраткоеНаимен",СокрЛП(СписокЯчеек.Элемент(3).ТекстовоеСодержимое));
		ОрганизацияГЛН.Вставить("Локация",      СокрЛП(СписокЯчеек.Элемент(4).ТекстовоеСодержимое));
		ОрганизацияГЛН.Вставить("Адрес",        СокрЛП(СписокЯчеек.Элемент(5).ТекстовоеСодержимое));
		
		// Безопасно извлекаем ссылку на просмотр из последней ячейки (индекс 6)
		Если СписокЯчеек.Количество() >= 7 Тогда
			ЯчейкаСсылки = СписокЯчеек.Элемент(6);
			СписокСсылок = ЯчейкаСсылки.ПолучитьЭлементыПоИмени("a");
			
			Если СписокСсылок.Количество() > 0 Тогда
				ЭлементA = СписокСсылок.Элемент(0);
				АтрибутHref = ЭлементA.Атрибуты.ПолучитьИменованныйЭлемент("href");
				Если АтрибутHref <> Неопределено Тогда
					ОрганизацияГЛН.Вставить("Ссылка", АтрибутHref.Значение);
				Иначе
					ОрганизацияГЛН.Вставить("Ссылка", "");
				КонецЕсли;
			Иначе
				ОрганизацияГЛН.Вставить("Ссылка", "");
			КонецЕсли;
		Иначе
			ОрганизацияГЛН.Вставить("Ссылка", "");
		КонецЕсли;
		
		МассивОрганизаций.Добавить(ОрганизацияГЛН);
	КонецЦикла;
	
	
	Возврат МассивОрганизаций;

КонецФункции

Процедура ОбновитьСрокиДействияГЛН(ОрганизацияДляПроверки, ГЛН = Неопределено) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИнформацияГЛН.ГЛН КАК ГЛН,
		|	ИнформацияГЛН.Организация КАК ОрганизацияДляПроверки
		|ИЗ
		|	РегистрСведений.ИнформацияГЛН КАК ИнформацияГЛН
		|ГДЕ
		|	ИнформацияГЛН.Организация = &Организация
		|	И (НЕ &ФильтрПоГЛН ИЛИ ИнформацияГЛН.ГЛН = &ГЛН)";
	
	Запрос.УстановитьПараметр("Организация", ОрганизацияДляПроверки);
	Запрос.УстановитьПараметр("ФильтрПоГЛН", ГЛН <> Неопределено);
	Запрос.УстановитьПараметр("ГЛН", ?(ГЛН = Неопределено, "", ГЛН));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ПроверитьЗаписатьСрокДействияГЛН(Выборка.ОрганизацияДляПроверки, Выборка.ГЛН);
	КонецЦикла;
		
КонецПроцедуры

Процедура ПроверитьЗаписатьСрокДействияГЛН(ОрганизацияДляПроверки, ГЛН)
	
	Результат = КоннекторHTTP.КакТекст(КоннекторHTTP.Get("https://ext.epass.by/epassorgglns/viewepassorg?gln=" + ГЛН));

	СрокДействияГЛН = СрокДействияГЛН(Результат);
	
	Если СрокДействияГЛН <> Дата(1, 1, 1) Тогда
		
		Набор = РегистрыСведений.ИнформацияГЛН.СоздатьНаборЗаписей();
		
		Набор.Отбор.Организация.Установить(ОрганизацияДляПроверки);
		Набор.Отбор.ГЛН.Установить(ГЛН);
		
		Набор.Прочитать();
		
		Если Набор.Количество() > 0 Тогда
			
			Запись = Набор[0];
			
			Запись.ДатаДействия = СрокДействияГЛН;
			Запись.ДатаЗагрузкиДанных = ТекущаяДата();
			
		КонецЕсли;
		
		Набор.Записать();
		
	КонецЕсли;
	
КонецПроцедуры

Функция СрокДействияГЛН(Результат)

	ИсходныйТекстHTML = Результат; 
	// Шаг 1. Инициализируем чтение и DOM-модель
	ЧтениеHTML = Новый ЧтениеHTML;
	ЧтениеHTML.УстановитьСтроку(ИсходныйТекстHTML);
	
	ПостроительDOM = Новый ПостроительDOM;
	ДокументDOM = ПостроительDOM.Прочитать(ЧтениеHTML);
	ЧтениеHTML.Закрыть();
	
	СрокДействия = Дата(1, 1, 1); // Значение по умолчанию (пустая дата)
	Маркер = "Срок окончания права использования присвоенного GLN:";
	
	// Шаг 2. Ищем все теги <label> на странице
	ВсеЛабелы = ДокументDOM.ПолучитьЭлементыПоИмени("label");
	
	Для Каждого ТекстовыйБлок Из ВсеЛабелы Цикл
		
		Текст = СокрЛП(ТекстовыйБлок.ТекстовоеСодержимое);
		
		// Шаг 3. Если нашли нужную строку, извлекаем дату
		Если Найти(Текст, Маркер) > 0 Тогда
			
			// Отрезаем маркер, оставляя только "11.08.2026"
			СтрокаДаты = СокрЛП(СтрЗаменить(Текст, Маркер, ""));
			
			// Разбиваем строку "11.08.2026" по точкам на массив: ["11", "08", "2026"]
			СтрокаЧастиДаты = СтрРазделить(СтрокаДаты, ".");
			
			Если СтрокаЧастиДаты.Количество() = 3 Тогда
				// Собираем в каноническую строку 1С: "2026" + "08" + "11" -> "20260811"
				СтрокаДляКонвертации = СтрокаЧастиДаты[2] + СтрокаЧастиДаты[1] + СтрокаЧастиДаты[0];
				СрокДействия = Дата(СтрокаДляКонвертации);
			КонецЕсли;
			
			Прервать; // Дата найдена, выходим из цикла
		КонецЕсли;
	КонецЦикла;
	
	СрокДействияГЛН = СрокДействия;
	
	Возврат СрокДействияГЛН;
	
КонецФункции